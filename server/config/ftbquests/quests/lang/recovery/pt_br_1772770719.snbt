			]
		}
		quest.38E1A4E0A032E377.quest_desc: {
			new: [
				"&bBuracos de Minhoca Estáveis&r agem como pontos de acesso colocáveis para o &bAtuador de Armazenamento&r. Itens podem ser encanados para dentro e fora deles, mas é recomendado usar um espírito transportador ao extrair deles devido a problemas de lag."
				""
				"O &bAcessor de Armazenamento&r é um dispositivo simples que permite &6interagir com seu armazenamento&r de longe. Não tem limite de alcance nem de dimensão, mas o atuador deve estar em chunk carregado."
			]
			old: [
				"&bBuracos de Minhoca Estáveis&r agem como pontos de acesso posicionáveis para o &bAtuador de Armazenamento&r. Itens podem ser inseridos e retirados deles, mas é recomendado usar um espírito transportador ao extrair deles para evitar lag."
				""
				"O &bAcessor de Armazenamento&r é um dispositivo simples que permite que você &6interaja com seu armazenamento&r de longe. Ele não tem limite de alcance nem de dimensão, mas o atuador deve estar carregado (chunk loaded)."
			]
		}
		quest.448D7A215A175817.quest_desc: {
			new: [
				"&bOcultismo&r é uma arte baseada em &6invocar Espíritos&r para realizar trabalhos para você."
				""
				"Você irá &6construir e refinar&r vários &bpentáculos rituais&r. Através destes, você irá &6invocar e comandar&r - e às vezes &6lutar contra&r - uma variedade de &bespíritos&r."
				""
				"Espíritos podem &6transportar&r &bitens&r para você, &6produzir e processar&r &bMinérios&r, fornecer buffs e protegê-lo, e mais."
				""
				"Ler o &bDicionário dos Espíritos&r é &laltamente recomendado&r, pois fornece um guia muito mais completo do que eu jamais serei, especialmente em relação aos muitos &bGizes&r."
				""
				"Pronto para ser um ocultista?"
			]
			old: [
				"&bOccultism&r é uma arte baseada em &6invocar Espíritos&r para realizar trabalhos para você."
				""
				"Você irá &6construir e refinar&r vários &bpentáculos rituais&r. Através deles, você irá &6invocar e comandar&r - e às vezes &6lutar&r - com uma variedade de &bespíritos&r."
				""
				"Espíritos podem &6transportar&r &bitens&r para você, &6produzir e processar&r &bMinérios&r, fornecer buffs e protegê-lo, e mais."
				""
				"Ler o &bDicionário de Espíritos&r é &laltamente recomendado&r, pois fornece um guia muito mais completo do que eu jamais fornecerei, especialmente em relação aos muitos &bGizes&r."
				""
