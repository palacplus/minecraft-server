		quest.378E30F8E12695A2.quest_desc: {
			new: ["A &bBase de Carregamento&r é uma base que pode ser &6colocada no chão&r e &6carregar&r qualquer coisa parada sobre ela; incluindo qualquer &euso de energia/baterias&r no inventário de um jogador parado sobre ela."]
