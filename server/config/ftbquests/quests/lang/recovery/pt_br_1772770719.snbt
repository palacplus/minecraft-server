		}
		quest.614E49D8AA7F85FC.quest_desc: {
			new: ["Cada &bProvedor de Indução de Elite&r adicionado à sua matriz adiciona &e9.55 MFE por tick&r de taxa de transferência de energia, dentro e fora de sua matriz."]
			old: ["Cada &bProvedor de Indução de Elite&r adicionado à sua matriz adiciona &e9.55 MFE por tick&r de taxa de transferência de energia, para dentro e para fora de sua matriz."]
		}
		quest.05A0AC380BB141A0.quest_desc: {
			new: ["O &bTransportador Restritivo&r é um tipo de &bTransportador Logístico&r que praticamente funciona como um tubo de \"&6excesso&r\". Assim que os &3itens&r não tiverem para onde ir, eles &6viajarão&r através do &bTransportador Restritivo&r."]
			old: ["O &bTransportador Restritivo&r é um tipo de &bTransportador Logístico&r que funciona praticamente como um cano de \"&6excesso&r\". Uma vez que os &3itens&r não têm para onde ir, eles &6viajarão&r através do &bTransportador Restritivo&r."]
		}
		quest.3BAA7EC7653A7905.quest_desc: {
			new: [
				"A &bCâmara de Injeção Química&r permite que você &6processe&r diferentes &9minérios&r e &cminérios brutos&r usando &7Cloreto de Hidrogênio&r em múltiplos &efragmentos&r como um primeiro passo para o processamento de minério de &a400%&r. "
				""
				"Você também pode usar &7oxigênio&r para &4oxidar&r forçadamente alguns materiais de cobre, vapor d'água para solidificar concreto, reverter o cozimento de argila, e reidratar coral morto."
			]
			old: [
				"A &bCâmara de Injeção&r permite que você &6processe&r diferentes &9minérios&r e &cminérios brutos&r usando &7Cloreto de Hidrogênio&r em múltiplos &efragmentos&r como um primeiro passo para o processamento de minério de &a400%&r."
