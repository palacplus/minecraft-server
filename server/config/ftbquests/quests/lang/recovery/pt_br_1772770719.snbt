		quest.5DD99224F29419C1.quest_desc: {
			new: [
				"  Este é o seu momento de produzir verdadeira &6eletricidade&r usando o &bVapor&r que você tem feito até agora. A &bTurbina a Vapor de BT&r converterá cada &61 mb de Vapor em 1 EU&r de energia e fará isso até 32 vezes por tick, fazendo uma &6taxa máxima de produção de energia de 32 EU/t&r."
				""
				"  A &bTurbina a Vapor&r enviará automaticamente eletricidade para qualquer máquina conectada diretamente ao seu lado de saída. Ela também se conectará apenas a cabos colocados em seu lado de saída."
				""
				"  A primeira que você fará é do nível de Baixa Tensão. Existem turbinas a vapor de nível superior, mas você ainda não chegou lá."
			]
			old: [
				"  Este é o seu momento de produzir &6eletricidade&r de verdade usando o &bVapor&r que você tem feito até agora. A &bTurbina a Vapor LV&r converterá cada &61 mb de Vapor em 1 EU&r de energia e fará isso até 32 vezes por tick, gerando uma &6taxa máxima de produção de energia de 32 EU/t&r."
				""
				"  A &bTurbina a Vapor&r enviará automaticamente eletricidade para qualquer máquina conectada diretamente ao seu lado de saída. Ela também só se conectará a cabos colocados em seu lado de saída."
				""
				"  A primeira que você fará é do nível de Baixa Tensão. Existem turbinas a vapor de nível superior, mas você ainda não chegou lá."
			]
		}
		quest.04A69DE982F47E64.quest_desc: {
			new: [
				"  Hora de outra grande atualização! Agora você poderá fazer um &6máximo de 512 eu/t&r com a nova &bTurbina a Vapor de AT&r! Além do aumento de quatro vezes na produção de energia (novamente), ela age exatamente como a Turbina a Vapor de BT e a de &bMT&r."
				""
				"  Você precisará usar um novo conjunto de cabos para AT agora. Você precisará usar cabos de &bAlumínio&r ou &bKanthal&r para poder transferir este novo nível de energia de AT."
			]
			old: [
				"  Hora de outra grande melhoria! Agora você poderá produzir um &6máximo de 512 eu/t&r com a nova &bTurbina a Vapor de AT&r! Além do aumento quádruplo na produção de energia (novamente), ela funciona exatamente como a de BT e &bMT&r."
				""
				"  Você precisará usar um novo conjunto de cabos para AT agora. Você precisará usar cabos de &bAlumínio&r ou &bKanthal&r para poder transferir esta nova energia de nível AT."
			]
		}
		quest.1094111FB9512D75.quest_desc: {
			new: [
				"  Existem três &bGeradores a Diesel Pequenos&r que são o início da geração de energia via fluidos ou gases. Você pode usar seu EMI para verificar quanto EU será produzido por milibalde de cada tipo de combustível."
				""
				"  O &bGerador a Diesel de BT&r produzirá até 64 eu/t, o &bGerador a Diesel de MT&r produzirá até 256 eu/t, e o &bGerador a Diesel de AT&r produzirá até 1024 eu/t."
				""
				"  &bGeradores a Diesel&r &6só usarão combustível quando precisarem&r, então não se preocupe em desperdiçar combustível quando não estiver usando energia. No entanto, se precisar de um fornecimento constante de energia, você pode colocar esses combustíveis fluidos na &bCaldeira a Vapor Grande&r (e níveis superiores dela) em vez de apenas itens."
				""
				"  Uma &bCaldeira a Vapor Grande&r totalmente aquecida &6produzirá a mesma quantidade de energia que um &bGerador a Diesel de MT&r produziria usando a mesma quantidade de combustível."
			]
			old: [
				"  Existem três &bGeradores a Diesel Pequenos&r que são o início da geração de energia por meio de fluidos ou gases. Você pode usar seu EMI para verificar quanto EU será produzido por milibalde de cada tipo de combustível."
				""
				"  O &bGerador a Diesel de BT&r produzirá até 64 eu/t, o &bGerador a Diesel de MT&r produzirá até 256 eu/t, e o &bGerador a Diesel de AT&r produzirá até 1024 eu/t."
				""
				"  Os &bGeradores a Diesel&r &6só usarão combustível quando precisarem&r, então não se preocupe em desperdiçar combustível quando não estiver usando energia. No entanto, se precisar de um fornecimento constante de energia, você pode colocar esses combustíveis fluidos na &bCaldeira a Vapor Grande&r (e em seus níveis superiores) em vez de apenas itens."
				""
				"  Uma &bCaldeira a Vapor Grande&r totalmente aquecida &6produzirá a mesma quantidade de energia que um &bGerador a Diesel de MT&r produziria usando a mesma quantidade de combustível."
			]
		}
