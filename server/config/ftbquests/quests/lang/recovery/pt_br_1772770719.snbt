		quest.6EF133E0EC49BC33.quest_desc: {
			new: [
				"  Flexível, não condutora e forte. &bBorracha&r será uma parte importante de cada máquina elétrica. Você pode produzi-la &6misturando&r &bPapel&r com &bÓleo Sintético&r ou &bBorracha Sintética&r. Misture o &bPó de Coque&r que você fez com &bÁgua&r em um &bMisturador&r para produzir &bÓleo Sintético Bruto&r. Use um &bAlto-forno a Vapor&r para produzir esses dois fluidos. &bBorracha Sintética&r é mais difícil de obter, &6mas renderá mais borracha por folha de papel&r."
				""
				"  Lembre-se de que você precisará de &omuitas&r &bFolhas de Borracha&r a longo prazo, então precisará fazê-las constantemente. Note que você pode usar &bMadeira&r para &6triturar&r e transformar em &bPolpa de Madeira&r, que pode então ser transformada em &bPapel&r com um alto rendimento de produção."
			]
			old: [
				"  Flex00edvel, n00e3o condutora e forte. A &bBorracha&r ser00e1 uma parte importante de toda m00e1quina el00e9trica. Voc00ea pode produzi-la &6misturando&r &bPapel&r com &b00d3leo Sint00e9tico&r ou &bBorracha Sint00e9tica&r. Misture o &bP00f3 de Coque&r que voc00ea fez com &b00c1gua&r em um &bMisturador&r para produzir &b00d3leo Sint00e9tico Bruto&r. Use um &bAlto-forno a Vapor&r para produzir esses dois fluidos. A &bBorracha Sint00e9tica&r 00e9 mais dif00edcil de obter, &6mas render00e1 mais borracha por folha de papel&r."
				""
				"  Lembre-se que voc00ea precisar00e1 de &omuitas&r &bFolhas de Borracha&r a longo prazo, ent00e3o voc00ea precisar00e1 faz00ea-las constantemente. Note que voc00ea pode usar &bMadeira&r para &6moer&r e transformar em &bPolpa de Madeira&r, que pode ent00e3o ser transformada em &bPapel&r com um alto rendimento."
			]
		}
		quest.21EDEEE1A1B82B53.quest_desc: {
			new: ["  Processando o &bMinério de Irídio&r de suas &bBrocas de Titânio&r, você pode começar a produzir &bPó de Irídio&r, que será necessário para &bPó Supercondutor&r, um material capaz de extraordinária transferência e armazenamento de energia."]
			old: ["  Processando o &bMinério de Irídio&r de suas &bBrocas de Titânio&r, você pode começar a produzir &bPó de Irídio&r, que será necessário para o &bPó de Supercondutor&r, um material capaz de extraordinária transferência e armazenamento de energia."]
		}
		quest.7533E0212EFE326D.quest_subtitle: {
			new: "Quando colocado de frente para uma &ecolmeia&r, &6mel&r será extraído em &bforma fluida&r."
			old: "Quando colocado virado para uma &bcolmeia&r, o &6mel&r ser00e1 extra00eddo na &bforma l00edquida&r."
		}
		quest.5C8D7BD3DA61109F.quest_desc: {
			new: [
				"  Você alcançou a versão elétrica da &bPedreira&r! Esta permite produzir minérios a uma taxa ainda mais rápida do que antes &oe&r lhe dá mais opções de brocas."
				""
				"  &6Agora você poderá usar &bBrocas de &bAço&r&6, &bOuro&r&6, &bAço Inoxidável&r&6 e &bTitânio&r para finalizar o restante da produção de minério e cumprir verdadeiramente minha promessa de nunca mais precisar minerar minérios!"
				""
				"  A estrutura é &oexatamente&r a mesma da &bPedreira a Vapor&r, exceto pela necessidade de uma &bEscotilha de Entrada de Energia&r em vez de uma &bEscotilha de Entrada de Fluido&r.&6 Certifique-se de ter automatizado suas &bBrocas de Bronze&r&r agora, senão será um sofrimento manter suas pedreiras funcionando."
			]
			old: [
				"  Você chegou à versão elétrica da &bPedreira&r! Esta permite que você produza minérios a uma taxa ainda mais rápida do que antes &oe&r te dá mais opções de brocas."
				""
				"  &6Agora você poderá usar brocas de &bAço&r&6, &bOuro&r&6, &bAço Inoxidável&r&6 e &bTitânio&r para finalizar o resto da produção de minério e realmente cumprir minha promessa de nunca mais precisar minerar minérios!"
				""
				"  A estrutura é &oexatamente&r a mesma da &bPedreira a Vapor&r, exceto por precisar de uma &bEscotilha de Entrada de Energia&r em vez de uma &bEscotilha de Entrada de Fluido&r.&6 Certifique-se de ter automatizado suas &bBrocas de Bronze&r&r até agora, ou será um pé no saco manter suas pedreiras funcionando."
			]
		}
		quest.0AC7D844C55119E1.quest_desc: {
			new: [
				"  Esta não é uma &bChave Grifo&r, mas é melhor você esperar poder se mover como uma no futuro."
				""
				"  Usando uma &bChave Inglesa&r, você pode &6rotacionar&r &oquase&r &bqualquer máquina&r clicando com o &6botão direito&6 e &rpegar&r &oquase&r qualquer &btubo&r, &bfluido&r ou &bnão&r."
				""
				"  Você pode &6segurar shift e clicar com o botão direito&o em uma &bmáquina&r para &6configurar&r o &blado de saída&r. Quando estiver &6segurando&r a &bChave Inglesa&r, você pode &6passar o mouse&r sobre qualquer face da &bmáquina&r e obterá uma espécie de &bgrade&r. &6Shift-clique direito&o no &bquadrado do meio&r definirá a &bface de saída&r para o lado em que a &bgrade&r está. Fazer isso nos retângulos &6colocará a saída&r na face a &690&r graus em relação ao canto escolhido para permitir &6configuração&r em espaços difíceis de alcançar. Finalmente, os pequenos &bquadrados&r em cada canto definirão a saída para o lado &boposto&r da grade."
				""
				"  Lembre-se, você não pode &6quebrar&r a máquina usando a &bChave Inglesa&r, isso VAI &6destruí-la&r e você &6não&r a terá de volta. Apenas use sua fiel &bPicareta&r em vez disso."
			]
			old: [
				"  Esta não é uma &bChave Inglesa de Macaco&r, mas é melhor você esperar poder se mover como um no futuro."
				""
				"  Usando uma &bChave Inglesa&r, você pode &6girar&r &oquase&r &bqualquer máquina&r &6clicando com o botão direito&6 e &rpegar&r&o quase&r qualquer &bcano&r, de &bfluido&r ou &bnão&r."
				""
				"  Você pode &6clicar com shift e botão direito&o em uma &bmáquina&r para &6configurar&r o &blado de saída&r. Quando você está &6segurando&r a &bChave Inglesa&r, pode &6passar o mouse&r sobre qualquer face da &bmáquina&r e obterá uma &bgrade&r de certa forma. &6Clicar com shift e botão direito&o no &bquadrado do meio&r definirá a &bface de saída&r para o lado em que a &bgrade&r está. Fazer isso nos retângulos &6colocará a saída&r na face a &690&r graus em relação ao canto eleito para permitir a &6configuração&r em espaços de difícil acesso. Finalmente, os pequenos &bquadrados&r em cada canto definirão a saída para o lado &boposto&r da grade."
				""
				"  Lembre-se, você não pode &6quebrar&r a máquina usando a &bChave Inglesa&r, ela VAI &6destruí-la&r e você &6não&r a terá de volta. Apenas use sua fiel &bPicareta&r em vez disso."
			]
		}
