		quest.186F257352F2E844.quest_desc: {
			new: ["  Esta máquina exige um nível totalmente diferente de força. Hora de colocar aquele novo &bTitânio&r que você fez em uso. O &bPressurizador&r permite pressurizar &bÁgua&r &6em &bAP&r&6, ou &bágua de alta pressão&6 e &r&bVapor&r &6em &bVapor AP&r. Também funciona no sentido inverso para despressurizar os fluidos. O &bPressurizador&r também &6permite coletar &bAr Líquido&r &6via &bEntrada de Ar&r, além de ser muito mais eficiente que o &bCongelador a Vácuo&r."]
			old: ["  Esta máquina exige um nível totalmente novo de força. É hora de usar aquele novo &bTitânio&r que você fez. O &bPressurizador&r permite que você pressurize &bÁgua&r &6em &bÁgua de Alta Pressão&6, ou &bAP&6, e &r&bVapor&r &6em &bVapor AP&r. Também funciona ao contrário para despressurizar os fluidos. O &bPressurizador&r também &6permite que você colete &bAr Líquido&r &6através da &bEntrada de Ar&r, e é muito mais eficiente que o &bCongelador a Vácuo&r."]
		}
		quest.61748279816F2D7F.quest_desc: {
			new: [
				"O &bMódulo de Controle de Redstone&f destina-se a permitir que você controle suas máquinas com &credstone&f! &6Clicar com o botão direito&f no módulo em sua mão &6mudará&f sua configuração da máquina exigindo um &9Sinal Alto&f para &9Sinal Baixo&f e vice-versa. Em seguida, coloque-o no slot do módulo de &credstone&f."
				""
				"O que isso significa é:"
				"- Enquanto a configuração estiver em &9Sinal Alto&f, a máquina só &6funcionará&f se receber um sinal de &credstone&f. Nenhum sinal de &credstone&f a desligará."
				"- Enquanto a configuração estiver em &9Sinal Baixo&f, a máquina só &6funcionará&f se não receber um sinal de &credstone&f. Um sinal de &credstone&f a desligará."
			]
			old: [
				"O &bMódulo de Controle de Redstone&f serve para que você possa controlar suas máquinas com &credstone&f! &6Clicar com o botão direito&f no módulo em sua mão &6mudará&f sua configuração de a máquina exigir um &9Sinal Alto&f para &9Sinal Baixo&f e vice-versa. Em seguida, coloque-o no slot do módulo de &credstone&f."
				""
				"O que isto significa é:"
				"- Enquanto a configuração estiver em &9Sinal Alto&f, a máquina só &6funcionará&f se receber um sinal de &credstone&f. Nenhum sinal de &credstone&f a desligará."
				"- Enquanto a configuração estiver em &9Sinal Baixo&f, a máquina só &6funcionará&f se não receber um sinal de &credstone&f. Um sinal de &credstone&f a desligará."
			]
		}
