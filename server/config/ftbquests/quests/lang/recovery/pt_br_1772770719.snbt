			old: "Canos de matéria permitirão que você conecte máquinas de &aReplicação&r."
		}
		quest.28EB489B44A05070.quest_desc: {
			new: ["&aReplicadores&r usarão a &dMatéria&r armazenada em tanques para replicar o item do zero e enviá-lo de volta ao &bterminal&r."]
			old: ["Os &aReplicadores&r usarão a &dMatéria&r armazenada em tanques para replicar o item do zero e enviá-lo de volta ao &bterminal&r."]
		}
		quest.4513758183EFECE7.title: {
			new: "&aReplication!"
			old: "&aReplicação!"
		}
		quest.6B5431B3A107C9D5.quest_desc: {
			new: [
				"Depois de escanear alguns itens e armazenar seus valores em &cchips&r, você pode usar o &aTerminal de Replicação&r para &6solicitar itens&r. "
				""
				"Com uma solicitação criada, &aReplicadores&r usarão a &dMatéria&r armazenada em tanques para replicar o item do zero e enviá-lo de volta ao &aterminal&r."
				""
				"{@pagebreak}"
				""
				"&dMateri&aOpédia&r é uma lista pesquisável que permitirá &6pesquisar&r quais itens têm um &dValor de Matéria&r específico. "
				""
				"Você pode acessar usando o botão à &9esquerda&r da &bBarra de Pesquisa&r na tela do &aTerminal de Replicação&r, você também pode acessá-la clicando nos displays de matéria à &9direita&r do terminal."
				""
				"Na barra de pesquisa da &dMateri&aOpédia&r você pode usar:"
				""
				"&l*&r &aearth>10&r mostrará todos os itens que têm mais de 10 de terra"
				""
				"&l*&r &4nether=20&r mostrará todos os itens que têm exatamente 20 de nether"
				""
				"&l*&r &dquantum<6&r mostrará todos os itens que têm menos de 6 de quantum"
				""
				"&l*&r &2!earth&r mostrará todos os itens que não têm terra"
				""
				"&l*&r &7*metallic&r mostrará todos os itens que têm apenas metálico"
			]
			old: [
				"Depois de escanear alguns itens e armazenar seus valores em &cchips&r, voc00ea pode usar o &aTerminal de Replica00e700e3o&r para &6solicitar itens&r."
				""
				"Com uma solicita00e700e3o criada, os &aReplicadores&r usar00e3o a &dMat00e9ria&r armazenada em tanques para replicar o item do zero e envi00e1-lo de volta para o &aterminal&r."
				""
				"{@pagebreak}"
				""
				"A &dMat00e9ria&aOp00e9dia&r 00e9 uma lista pesquis00e1vel que permitir00e1 que voc00ea &6procure&r quais itens t00eam um &dValor de Mat00e9ria&r espec00edfico."
				""
				"Voc00ea pode acess00e1-la usando o bot00e3o 00e0 &9esquerda&r da &bBarra de Pesquisa&r na tela do &aTerminal de Replica00e700e3o&r; voc00ea tamb00e9m pode acess00e1-la clicando nos mostradores de mat00e9ria 00e0 &9direita&r do terminal."
				""
				"Na barra de pesquisa da &dMat00e9ria&aOp00e9dia&r, voc00ea pode usar:"
				""
				"&l*&r &aterra>10&r mostrar00e1 todos os itens que t00eam mais de 10 de terra"
				""
				"&l*&r &4nether=20&r mostrar00e1 todos os itens que t00eam exatamente 20 de nether"
				""
				"&l*&r &dquantum<6&r mostrar00e1 todos os itens que t00eam menos de 6 de quantum"
				""
				"&l*&r &2!terra&r mostrar00e1 todos os itens que n00e3o t00eam terra"
				""
				"&l*&r &7*met00e1lico&r mostrar00e1 todos os itens que t00eam apenas met00e1lico"
			]
		}
	}
	"chapters/Create.snbt": {
		quest.0A67575BAF8596B0.quest_desc: {
			new: ["Melhor que seus trilhos de trem de maquete: retas, curvas (dois tipos) e inclinações—funciona através de portais do Nether e chunks não carregados também!"]
			old: ["Melhor do que seus trilhos de trem de brinquedo: retas, curvas (de dois tipos) e rampas—funciona através de portais do Nether e chunks descarregados também!"]
		}
		quest.1CACDF56CB395997.quest_subtitle: {
			new: "Mãos para o alto!"
			old: "Alcance o céu!"
		}
		quest.6711E72048BBDB08.quest_desc: {
			new: ["&6Comporta&r bastante de até oito coisas diferentes, colorível, e todas as &bCaixas de Ferramentas&r próximas podem ser &6acessadas&r com um atalho—útil para manter seus olhos no seu trabalho, não em suas ferramentas."]
			old: ["&6Armazena&r bastante de até oito coisas diferentes, é colorível, e todas as &bCaixas de Ferramentas&r próximas podem ser &6acessadas&r com uma única tecla de atalho—útil para manter seus olhos no trabalho, não em suas ferramentas."]
		}
		quest.1FDE63D5EA5DA3CB.quest_subtitle: {
			new: "Não é onde sapos pousam e decolam."
			old: "Não é onde os sapos pousam e decolam."
		}
		quest.33C2042F320B2D34.quest_desc: {
			new: [
				"Calhas são mais flexíveis do que você pode pensar a princípio."
				""
				"Elas podem empilhar verticalmente, mas também diagonalmente."
				""
				"Uma Chave Inglesa irá colocar, ou remover, janelas em Calhas."
				""
				"Move itens para cima, usando Ventiladores Encaixotados em qualquer extremidade para forçar o ar para cima."
				""
				"Mova itens para baixo com... nada mais. (obrigado, gravidade!)"
			]
			old: [
				"Calhas são mais flexíveis do que você pode pensar a princípio."
				""
				"Elas podem ser empilhadas verticalmente, mas também diagonalmente."
				""
				"Uma Chave Inglesa colocará ou removerá janelas nas Calhas."
				""
