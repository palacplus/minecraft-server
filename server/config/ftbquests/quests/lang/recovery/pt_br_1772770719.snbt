		quest.2472B23BC0C28C6C.quest_desc: {
			new: [
				"  Lembra daqueles \"ticks\" sobre os quais falamos? Como cada um é um vigésimo de segundo?"
				""
				"  Bem, você atingiu &oesse&r nível de processamento de máquina. Dada entrada de energia suficiente, cada receita de máquina, não importa a máquina, desde que seja elétrica, levará apenas um único tick."
				""
				"  Esteja ciente de que a quantidade de energia que essas máquinas podem usar será imensa, então use-as com sabedoria."
			]
			old: [
				"  Lembra daqueles \"ticks\" sobre os quais falamos? Como cada um é um vigésimo de segundo?"
				""
				"  Bem, você alcançou &oaquele&r nível de processamento de máquina. Com energia de entrada suficiente, cada receita de máquina, não importa a máquina, desde que seja elétrica, levará apenas um único tick."
				""
				"  Esteja ciente de que a quantidade de energia que essas máquinas podem usar será imensa, então use-as com sabedoria."
			]
		}
		quest.2FB2FE782B1103D6.quest_desc: {
			new: [
				"  Seu segundo multibloco: O &bAlto-forno a Vapor&r! Este é quase o mesmo, com a única diferença sendo que é um pouco mais alto e usa &bTijolos de Argila de Fogo&r em vez de &bTijolos&r comuns."
				""
				"  Use o mesmo truque com a &bChave Inglesa&r &6para mostrar as colocações dos blocos&r e não esqueça que você precisará apenas de &63 escotilhas&r desta vez. Elas são as mesmas que as do &bForno de Coque&r, sem a escotilha de saída de fluido, ainda não, de qualquer maneira!"
				""
				"  Você usará este &bAlto-forno a Vapor&r para fazer seu primeiro &bAço&r!"
			]
			old: [
				"  Seu segundo multibloco: O &bAlto-forno a Vapor&r! Este é quase o mesmo, com a única diferença sendo que é um bloco mais alto e usa &bTijolos de Argila Refratária&r em vez de &bTijolos&r normais."
				""
				"  Use o mesmo truque com a &bChave Inglesa&r &6para mostrar a você o posicionamento dos blocos&r e não se esqueça que você precisará de apenas &63 escotilhas&r desta vez. Elas são as mesmas do &bForno de Coque&r, sem a escotilha de saída de fluido, pelo menos por enquanto!"
				""
				"  Você usará este &bAlto-forno a Vapor&r para fazer seu primeiro &bAço&r!"
			]
		}
