			old: ["Construa um &bCarregador&r e energize-o com uma &bCâmara de Vibração&r ou geradores de outros mods."]
		}
		quest.20F99CBAD8D587DA.quest_desc: {
			new: ["Para obter &bCertus&f você deve primeiro ir ao &bMeteorito&f e pegar pelo menos 5 &bQuartzo Certus&f, e &6criar&f 1 drusa &bDrusa de Certus&f, com o &bbloco de Drusa &bvocê pode &6colocá-lo &fno chão e esperar que cresça. Quando os &bCristais &fcrescem, o &bBloco de Drusa &ftem uma chance de &6degradar&f ao ponto de ser apenas um &bBloco de Certus&f e não crescer mais."]
			old: ["Para obter &bCertus&f, você deve primeiro ir ao &bMeteorito&f e pegar pelo menos 5 &bQuartzo Certus&f, e &6criar&f 1 &bCertus Brotando&f, com o &bbloco Brotando &bvocê pode &6colocá-lo &fno chão e esperar que ele cresça. Quando os &bCristais &fcrescem, o &bBloco Brotando &ftem a chance de &6degradar&f ao ponto de ser apenas um &bBloco de Certus&f e não crescer mais."]
		}
		quest.2190034B6F3E2768.quest_desc: {
			new: ["Estes são os componentes primários de &bDispositivos de Entrada e Saída&f."]
			old: ["Estes são os componentes primários dos &bDispositivos de Entrada e Saída&f."]
		}
		quest.2E883FCCA2FB281B.quest_desc: {
			new: ["Configurando dois &bAnéis Quânticos&f, você pode conectar seu &bSistema ME&f a qualquer lugar do mundo. Conecte o primeiro ao seu &bSistema ME&f e o segundo onde deseja ter seu &bSistema ME&f vinculado. Você precisará de 2 &bSingularidades Entrelaçadas&f, coloque uma delas em cada &bAnel Quântico&f, após o que eles estarão vinculados."]
			old: ["Configurando dois &bAnéis Quânticos&f, você pode conectar seu &bSistema ME&f a qualquer lugar do mundo. Conecte o primeiro ao seu &bSistema ME&f e o segundo onde você deseja que seu &bSistema ME&f seja vinculado. Você precisará de 2 &bSingularidades Entrelaçadas&f, coloque uma delas em cada &bAnel Quântico&f, após o que eles serão vinculados."]
		}
