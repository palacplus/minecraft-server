		quest.4E97BABA7D6B07FE.quest_desc: {
			new: [
				"Fazenda passiva de colheita e árvores."
				""
				"- Alcance: &910 blocos&r da &bFlor Whirlisprig&r."
				""
				"- Progresso: 250. (por padrão)"
				""
				"- Como obter mais saque*: variedade é a chave."
				"- Como preencher o progresso mais rápido*: quantidade é a chave."
				""
				"- Invocação: &6clique com o botão direito&r em uma &bflor&r "
				"&8(converterá a flor em Flor Whirlisprig)"
				""
				"- Usando o Whirlisprig: coloque um &barmazenamento&r &6tocando&r a &bFlor Whirlisprig&r."
				"W: Flor Whirlisprig | "
				"C: baú (ou outros armazenamentos)"
				" C "
				"CWC"
				" C"
				""
				"- Fonte necessária: SIM."
				""
				""
				"&8*Whirlisprig em profundidade na &bpróxima página &8(WiP)"
				""
				"{@pagebreak}"
				"&2Whirlisprig&r vê blocos em &93 estados&r (quando você &6clica com o botão direito&r nele com o bloco):"
				"&8- GOSTA_UM_POUCO (impulso normal para o humor), +1 "
				"&8- GOSTA_MUITO (maior impulso para o humor), +2"
				"&8- DROP_NEGADO"
				""
				"Então tem 3 outros números para acompanhar:"
				"&8- moodScore (influencia &6progresso&r &8; expresso por quão &2\"feliz\"&r &8ele está)"
				""
				"&8- diversityScore (quantas &9vezes&r &8ele pega da tabela de saque gerada)"
				"&8quantos blocos/colheitas únicos &6ACEITOS&r existem"
				""
				"&8- progress (quando estiver cheio, gerará &6saque&8)"
				"&8progress += &6moodScore&r &8/ 30;"
				"&8redefine para 0 após depositar saque;"
				""
				"&8Para pessoas normais: novo_progresso = progresso_antigo + &6moodScore&r &8/ 30;"
				""
				"&8Não acredito que haveria página 3 ..."
				"{@pagebreak}"
				"&lComo faz no código:&r"
				"1. Calcula &bmoodScore&r de &9TODOS&r os blocos no alcance. (ele passa por cada bloco)"
				"&8(após o &950º&r &8do mesmo bloco/colheita, NÃO contará &6MAIS&r &8para esse bloco/colheita)"
				""
				"2. Aumenta o progresso até encher."
				""
				"3. Gera a tabela de saque."
				""
				"4. &8((diversityScore / 2) + 3)&r vezes ele faz getDrops()"
				"&8Você precisa descobrir isso sozinho (muito para mim)"
				"&8Arquivo é: WhirlisprigTile.java"
				""
				"5 Deposita no bloco de &barmazenamento&r ao lado da flor."
			]
			old: [
				"Fazenda passiva de plantações e árvores."
				""
				"- Alcance: &910 blocos&r da &bFlor de Whirliprig&r."
				""
				"- Progresso: 250. (por padrão)"
				""
				"- Como obter mais loot*: a variedade é a chave."
				"- Como preencher o progresso mais rápido*: a quantidade é a chave."
				""
				"- Invocação: &6clique com o botão direito&r em uma &bflor&r "
				"&8(converterá a flor em Flor de Whirliprig)"
				""
				"- Usando o Whirliprig: coloque um &barmazenamento&r &6tocando&r na &bFlor de Whirliprig&r."
				"W: Flor de Whirliprig | "
				"B: baú (ou outros armazenamentos)"
				" B "
				"BWB"
				" B"
				""
				"- Fonte necessária: SIM."
				""
				""
				"&8*Whirlisprig em profundidade na &bpróxima página &8(Em desenvolvimento)"
				""
				"{@pagebreak}"
				"O &2Whirlisprig&r vê os blocos em &93 estados&r (quando você &6clica com o botão direito&r nele com o bloco):"
				"&8- GOSTA_UM_POUCO (impulso normal ao humor), +1 "
				"&8- GOSTA_MUITO (maior impulso ao humor), +2"
				"&8- DROP_NEGADO"
				""
				"Depois, ele tem outros 3 números para acompanhar:"
				"&8- pontuaçãoDeHumor (influencia o &6progresso&r &8; expresso por quão &2\"feliz\"&r &8ele está)"
				""
				"&8- pontuaçãoDeDiversidade (quantas &9vezes&r &8ele pega da tabela de loot gerada)"
				"&8quantos blocos/plantações &6ACEITOS&r &8únicos existem"
				""
				"&8- progresso (quando está cheio, ele gerará &6loot&8)"
				"&8progresso += &6pontuaçãoDeHumor&r &8/ 30;"
				"&8reseta para 0 após depositar o loot;"
				""
				"&8Para pessoas normais: novo_progresso = progresso_antigo + &6pontuaçãoDeHumor&r &8/ 30;"
				""
				"&8Não acredito que haverá página 3 ..."
				"{@pagebreak}"
				"&lComo funciona no código:&r"
				"1. Calcula a &bpontuaçãoDeHumor&r de &9TODOS&r os blocos no alcance. (ele passa por todos os blocos)"
				"&8(após o &950º&r &8do mesmo bloco/plantação, ele NÃO contará &6MAIS&r &8para aquele bloco/plantação)"
				""
				"2. Aumenta o progresso até encher."
				""
				"3. Gera a tabela de loot."
				""
				"4. &8((pontuaçãoDeDiversidade / 2) + 3)&r vezes ele executa getDrops()"
				"&8Você precisa descobrir isso sozinho (muito para mim)"
				"&8O arquivo é: WhirlisprigTile.java"
				""
				"5 Deposita no bloco de &barmazenamento&r ao lado da flor."
			]
		}
