		quest.3DF6354F7AC8D4A4.quest_desc: {
			new: ["  Agora que você pode começar sua jornada nos produtos químicos ramificando do &bPetróleo Bruto&r, você pode produzir melhorias para suas máquinas! Todas as máquinas elétricas que você usou até agora têm um overclock máximo de 32 eu/t. Agora, você pode aumentar esse máximo, dependendo do nível de melhoria que usar. Verifique seu EMI para ver quanto EU cada melhoria aumenta."]
			old: ["  Agora que você pode começar sua jornada nos produtos químicos derivados do &bPetróleo Bruto&r, você pode produzir melhorias para suas máquinas! Todas as máquinas elétricas que você usou até agora tinham um overclock máximo de 32 eu/t. Agora, você pode aumentar esse máximo, dependendo do nível da melhoria que usar. Verifique seu EMI para ver quanto de EU cada melhoria aumenta."]
		}
		quest.7FD5FCEFE3697A7C.quest_desc: {
			new: [
				"Por apenas &oinsignificantes&r &e8EU/t&r, o &bFazendeiro a Vapor&r pode realizar as seguintes coisas:"
				"- &6Arar&r: Quando ativado, blocos de terra serão transformados em terra arada. Isso não funcionará a menos que água seja fornecida."
				"- &6Hidratar&r: Quando fornecido com água, o solo arado será hidratado."
				"- &6Colher&r: Quando houver espaço de saída suficiente fornecido, colherá plantações e árvores totalmente crescidas."
				"- &6Plantar&r: Quando fornecido com sementes ou mudas, plantará em solo válido. Usar diferentes modos de plantio plantará em arranjos diferentes."
			]
			old: [
				"Por apenas &bmíseros&r &e8EU/t&r, o &bFazendeiro a Vapor&r pode realizar as seguintes tarefas:"
				"- &6Arar&r: Quando habilitado, blocos de terra serão transformados em terra arada. Isso não funcionará a menos que água seja fornecida."
				"- &6Hidratar&r: Quando abastecido com água, o solo arado será hidratado."
				"- &6Colher&r: Quando houver espaço de saída suficiente, ele colherá plantações e árvores totalmente crescidas."
				"- &6Plantar&r: Quando abastecido com safras ou mudas, ele as plantará em solo válido. Usar diferentes modos de plantio as plantará em diferentes arranjos."
			]
		}
		quest.5676B5FD97FB10C3.quest_desc: {
