		quest.163BCEEEE08F3898.quest_desc: {
			new: [
				"  O &bPolarizador&r, bem, polariza coisas! O que isso significa é que seus ||elétrons|| são alinhados e, assim, o metal que você coloca nele se torna magnético."
				""
				"  &bBarras Polarizadas&r não têm muitos usos, mas &6usá-las para a automação de motores é perfeito&r!"
				"{image:modern_industrialization:block/machines/polarizer/overlay_front_active width:32 height:32 align:center}"
			]
			old: [
				"  O &bPolarizador&r, bem, polariza coisas! O que isso significa é que seus ||elétrons|| são alinhados e, assim, o metal que você insere nele se torna magnético."
				""
				"  As &bVaras Polarizadas&r não têm muitos usos, mas &6usá-las para a automação de motores é perfeito&r!"
				"{image:modern_industrialization:block/machines/polarizer/overlay_front_active width:32 height:32 align:center}"
			]
		}
		quest.07FE9074247583EE.quest_desc: {
			new: [
				"  Agora, você deve ter notado que eu disse \"geralmente\" ao falar sobre interagir com o controlador. Isso significa que itens e &6fluidos não podem ser inseridos ou extraídos do controlador&r, mas informações podem; no sentido de estatísticas. Olhando para o controlador, você verá algumas coisas: Validade do Formato, Status, Progresso, Base da Receita e Receita Atual."
				""
				"  A Validação do Formato informará se o &6multibloco foi construído corretamente ou não&r. Ele não dirá se você está perdendo ou tem escotilhas demais no multibloco, então você precisa decidir isso por si mesmo. Tenha em mente que estruturas multibloco &opodem&r compartilhar blocos umas com as outras, desde que esses blocos sobrepostos NÃO contenham uma escotilha."
				""
				"  Status informará o status atual do Multibloco. Se está ocioso ou ativo."
				""
				"  Progresso mostrará o progresso, construindo lentamente uma porcentagem até 100%. Dependendo da velocidade do processo, mais rápido a porcentagem aumentará."
				""
				"  Base da Receita mostra o &6consumo base de energia/vapor da receita&r. Dependendo do que você está fazendo, ela usa uma quantidade mínima de energia/vapor, mas pode usar mais para acelerar o processo. Isso não acontece em máquinas a vapor, então não vou me aprofundar muito nisso agora."
				""
				"  Receita Atual é a &6quantidade atual de energia/vapor sendo realmente consumida&r."
			]
			old: [
				"  Agora, você pode ter notado que eu disse \"geralmente\" ao falar sobre interagir com o controlador. Isso significa que itens e &6fluidos não podem ser inseridos ou extraídos do controlador&r, mas informações podem; no sentido de estatísticas. Olhando para o controlador você verá algumas coisas: Validade da Forma, Status, Progresso, Base da Receita e Receita Atual."
				""
				"  A Validação da Forma informará se o &6multiblock está construído corretamente ou não&r. Não dirá se você está faltando ou tem escotilhas demais no multiblock, então você precisa decidir isso por si mesmo. Lembre-se que estruturas de multiblock &opodem&r compartilhar blocos umas com as outras, desde que esses blocos sobrepostos NÃO contenham uma escotilha."
				""
				"  O Status informará o status atual do Multiblock. Se está ocioso ou se está ativo."
				""
				"  O Progresso mostrará o progresso, construindo lentamente uma porcentagem até 100%. Dependendo da velocidade do processo, mais rápido a porcentagem subirá."
				""
				"  A Base da Receita mostra o &6consumo base de energia/vapor da receita&r. Dependendo do que você está fazendo, ele usa uma quantidade mínima de energia/vapor, mas pode usar mais para acelerar o processo. Isso não acontece em máquinas a vapor, então não vou me aprofundar muito nisso agora."
				""
				"  A Receita Atual é a&6 quantidade atual de energia/vapor sendo realmente consumida&r."
			]
		}
		quest.2D4170B5AD28DCBF.quest_desc: {
			new: [
				"  O melhor &bGerador a Diesel&r de bloco único que você pode fazer. &6Ele produzirá até 1024 eu/t&r de qualquer um dos vários fluidos listados no seu EMI."
				""
				"  Agora, este não é o melhor gerador que aceitará combustíveis fluidos. Existe o &bGerador a Diesel Grande&r que solicitará &bCascos de Máquina Altamente Avançados&r; embora valha a pena quando você ouvir que &6ele gerará até 16.384 eu/t&r!"
			]
			old: [
				"  O melhor &bGerador a Diesel&r de um único bloco que você pode fazer. &6Ele produzirá até 1024 eu/t&r a partir de qualquer um dos vários fluidos listados no seu EMI."
				""
				"  Agora, este não é o melhor gerador que aceita combustíveis fluidos. Existe algo como um &bGrande Gerador a Diesel&r que exigirá &bCarcaças de Máquina Altamente Avançadas&r; embora valha a pena quando você ouvir que &6ele gerará até 16.384 eu/t&r!"
			]
		}
