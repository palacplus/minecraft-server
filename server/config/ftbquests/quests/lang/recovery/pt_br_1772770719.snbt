		quest.088E87F861406342.quest_desc: {
			new: ["Use para &6encher&r seu fosso, &6drenar&r um pântano, &6bombear&r &9água&r ou &blava&r sem limite."]
			old: ["Use-o para &6encher&r seu fosso, &6drenar&r um pântano, &6bombear&r &9água&r ou &blava&r sem limite."]
		}
		quest.55696F71CC09E588.quest_desc: {
			new: [
				"Este capítulo é oferecido como uma galeria do Create—um mod de muitos talentos:"
				""
				"- &6Mecanizar&r peças, recursos, agricultura, produção de energia e mais."
				"- &6Adicionar&r movimento mecânico às suas construções"
				"- &6Construir&r e &6agendar&r trens, incluindo uma rede de entrega de correio."
				"- &6Mover&r e &6armazenar itens e fluidos"
				"- &6Construir&r uma fábrica inteligente"
				"- &6Copiar e colar&r construções, ou &6importá-las&r."
				"- &6Encher&r, &6drenar&r, ou &6explorar&r corpos d'água ou lava"
				""
				"Este capítulo não é um conjunto de caminhos através do mod."
				"O próprio Create fornece excelentes informações sobre seus componentes com informações estendidas ao passar o mouse e o inovador sistema de &6Ponderar&r."
			]
			old: [
				"Este capítulo é oferecido como uma galeria do Create—um mod de muitos talentos:"
				""
				"- &6Mecanize&r peças, recursos, agricultura, produção de energia e muito mais."
				"- &6Adicione&r movimento mecânico às suas construções"
				"- &6Construa&r e &6agende&r trens, incluindo uma rede de entrega de correio."
				"- &6Mova&r e &6armazene itens e fluidos"
				"- &6Construa&r uma fábrica inteligente"
				"- &6Copie e cole&r construções, ou &6importe&r-as."
				"- &6Encha&r, &6drene&r, ou &6explore&r corpos de água ou lava"
				""
				"Este capítulo não é um conjunto de caminhos através do mod."
				"O próprio Create fornece informações excelentes sobre seus componentes com informações estendidas ao passar o mouse e o inovador sistema de &6Reflexão&r."
			]
		}
		quest.0807F0094282C2D5.quest_desc: {
			new: [
				"&bTúneis de Andesito&r são bem básicos, &6fornecendo&r cobertura para &bCorreias&r e introduzindo o &6fracionamento&r básico de itens transportados nelas."
				""
