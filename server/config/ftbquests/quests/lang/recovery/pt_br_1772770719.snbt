			]
		}
		quest.5401B18217772D6C.quest_desc: {
			new: [
				"  Você pode usar o &bTrocador de Calor&r para, bem, trocar calor. Você pode recuperar a &bÁgua de Alta Pressão&r para ser usada em outro ciclo. "
				""
				"  Lembre-se de que &6pressurizar &bÁgua&r &6em &bÁgua de Alta Pressão&r &6custa muita energia&r, mas a turbina não necessariamente a devolverá."
			]
			old: [
				"  Você pode usar o &bTrocador de Calor&r para, bem, trocar calor. Você pode recuperar a &bÁgua de Alta Pressão&r para ser usada em outro ciclo. "
				""
				"  Lembre-se que &6pressurizar &bÁgua&r &6em &bÁgua de Alta Pressão&r &6custa muita energia&r, mas a turbina não necessariamente a devolverá."
			]
		}
		quest.7AF270EF635B11CF.title: {
			new: "Chapa de Liga à Prova de Explosão"
			old: "Chapa de Liga 00e0 Prova de Explos00e3o"
		}
		quest.7D0CF81F7E703B71.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/water_pump/overlay_front_active width:32 height:32 align:center}"
				""
				"  Querendo saber sobre bombeamento automático de &bÁgua&r, está? Que bom que você pode fazer quase tudo o que quiser! Uma &bBomba d'Água&r coletará automaticamente &bÁgua&r e a &6transferirá para blocos adjacentes&r. Certifique-se de colocar fontes de água ao redor da bomba horizontalmente, dê &bVapor&r a ela, e ela começará a produzir &bÁgua&r por 1 EU/t."
				""
				"  A &bBomba d'Água de Bronze&r produzirá &6125mb de &bÁgua&r para cada fonte de água adjacente a cada 5 segundos&r, permitindo uma saída máxima de 1000mb a cada 5 segundos."
			]
			old: [
				"{image:modern_industrialization:block/machines/water_pump/overlay_front_active width:32 height:32 align:center}"
				""
				"  Est00e1 se perguntando sobre o bombeamento autom00e1tico de &b00c1gua&r? Que bom que voc00ea pode fazer quase tudo o que quiser! Uma &bBomba d'00c1gua&r coletar00e1 &b00c1gua&r automaticamente e a &6transferir00e1 para os blocos adjacentes&r. Certifique-se de colocar fontes de 00e1gua ao redor da bomba horizontalmente, d00ea a ela &bVapor&r, e ela come00e7ar00e1 a produzir &b00c1gua&r por 1 EU/t."
				""
				"  A &bBomba d'00c1gua de Bronze&r produzir00e1 &6125mb de &b00c1gua&r para cada fonte de 00e1gua adjacente a cada 5 segundos&r, permitindo uma sa00edda m00e1xima de 1000mb a cada 5 segundos."
			]
		}
		quest.6F57A2A5AA6E3F49.quest_subtitle: {
			new: "Doce, Doce Petróleo"
			old: "00d3leo, Doce 00d3leo"
		}
		quest.22420EF3089DD7F6.quest_desc: {
			new: ["  Seu primeiro gosto de verdadeira &4a&r&6u&r&et&r&2o&r&am&r&ba&r&3ç&r&9ã&r&do&r! Esta também é a primeira máquina da qual você vai querer fazer muitas. O &bMontador&r permite que você &6automatize&r quase todas as receitas relacionadas às máquinas. Verifique seu &bEMI&r para ver quais receitas você tem permissão para automatizar usando o &bMontador&r. Você pode configurar até &63 receitas em um montador&r usando &6bloqueio de slot&r. Apenas lembre-se de que ele fará tantas da primeira receita antes de passar para a próxima, &6então nunca coloque várias receitas de alta demanda em um único montador&r."]
			old: ["  Sua primeira experiência com a verdadeira &4a&r&6u&r&et&r&2o&r&am&r&ba&r&3ç&r&9ã&r&do&r&5!&r Esta também é a primeira máquina da qual você vai querer fazer muitas. O &bMontador&r permite &6automatizar&r quase todas as receitas relacionadas às máquinas. Verifique seu &bEMI&r para ver quais receitas você pode automatizar usando o &bMontador&r. Você pode configurar até &63 receitas em um montador&r usando o &6travamento de slot&r. Apenas lembre-se que ele fará o máximo possível da primeira receita antes de passar para a próxima, &6então nunca coloque várias receitas de alta demanda em um único montador&r."]
		}
		quest.668453E081A6C57B.quest_desc: {
			new: [
				"  Forjado no coração de supernovas, o &bTitânio&r tem a maior relação resistência-peso. É tão forte quanto o aço por 45% menos massa, tornando-o extremamente poderoso para seu peso."
				""
				"  Não é magnético, corrosivo, nem conduz eletricidade, então usá-lo para partes de uma máquina pode ser extremamente benéfico."
				""
				"  Sua cor rosa vem de alguma coisa?"
			]
			old: [
				"  Forjado no coração de supernovas, o &bTitânio&r tem a maior relação resistência/peso. É tão forte quanto o aço com 45% menos massa, tornando-o extremamente poderoso para o seu peso."
				""
				"  Não é magnético, corrosivo, nem conduz eletricidade, então usá-lo para peças de uma máquina pode ser extremamente benéfico."
				""
				"  Sua cor rosa vem de algo?"
			]
		}
		quest.6F57A2A5AA6E3F49.quest_desc: {
			new: [
				"  Petróleo é um líquido inflamável preto que se forma no solo ao longo de um &omuito&r longo tempo. &6Usando uma &bPlataforma de Perfuração&r&6, você pode perfurar o solo e extrair este petróleo&r."
				""
				"  Petróleo não é a única coisa que pode ser bombeada do chão, no entanto. Usar diferentes tipos de brocas decide qual fluido minerar. Use seu EMI para ver quais brocas mineram qual fluido."
				""
				"  P.S. Não esqueça, este é um daqueles multiblocos muito complexos. &6Use sua &bChave Inglesa&r &6para mostrar como construí-lo&r!"
			]
			old: [
				"  O petr00f3leo 00e9 um l00edquido preto inflam00e1vel que se forma no solo ao longo de um tempo &omuito&r longo. &6Usando uma &bPlataforma de Perfura00e700e3o&r&6, voc00ea pode perfurar o solo e extrair este petr00f3leo&r."
				""
				"  O petr00f3leo n00e3o 00e9 a 00fanica coisa que pode ser bombeada do ch00e3o. O uso de diferentes tipos de brocas decide qual fluido minerar. Use seu EMI para ver quais brocas mineram qual fluido."
				""
				"  P.S. N00e3o se esque00e7a, este 00e9 um daqueles multiblocos muito complexos. &6Use sua &bChave Inglesa&r &6para mostrar como constru00ed-lo&r!"
			]
		}
		quest.29E6ED5067027F08.quest_desc: {
			new: [
				"- Pode executar &6receitas&r de qualquer &bmáquina&r de criação &eelétrica&r de bloco único fornecida a ela em lotes."
				""
				"- O tamanho do lote é determinado pela quantidade de &bmáquinas&r fornecidas a ela."
				""
				"- Insira máquinas de criação &eelétricas&r para rodar em &6paralelo&r."
			]
			old: [
				"- Pode executar &6receitas&r de qualquer &bmáquina&r de criação &eelétrica&r de bloco único fornecida a ele em lotes."
				""
				"- O tamanho do lote é determinado pela quantidade de &bmáquinas&r fornecidas a ele."
				""
				"- Insira máquinas de criação &eelétricas&r para executar em &6paralelo&r."
			]
		}
		quest.39FCE3168C26B863.title: {
			new: "Coque"
			old: "Carvão de Coque"
		}
		quest.64287B360B07BEBB.quest_subtitle: {
			new: "Encadeie-as!"
			old: "Acorrente-os!"
		}
		quest.454FF6E2926163F7.quest_desc: {
			new: [
				"  Honestamente, não posso culpá-lo. Embora se você veio aqui depois de ter feito seu reator super incrível por curiosidade, eu o elogio. Mas para aqueles de vocês que precisavam de ajuda, por que não começamos? Prestem atenção!"
				""
				"  O &bReator Nuclear&r pode produzir 100s de vezes mais EU/t do que o diesel pode. Ele vem em vários tamanhos, de &bpequeno&r a &bextremo&r."
				""
				"  Como funciona nos bastidores pode ser um pouco avassalador, no entanto, você não precisa entender os detalhes para poder projetar um reator poderoso."
				""
				"  &6Note que neste mundo, o &bReator Nuclear&r &6&onão pode&r &6explodir, emitir radiação ou de outra forma danificar a área circundante&r. A única coisa que ele pode danificar são os itens que você coloca nele se a temperatura ficar muito alta, sobre o que falarei mais tarde. Sinta-se à vontade para experimentar e aproveite sua nova vida como cientista nuclear!"
				""
				"  O componente principal é o &bRevestimento Nuclear&r, que é feito com &bLiga Nuclear&r; uma mistura de &bcádmio&r, &bberílio&r e &bliga à prova de explosão&r."
				""
				"  A parte superior da estrutura aceita &bEscotilhas de Item&r ou &bFluido Nuclear&r ou apenas revestimentos simples. &6Essas são as entradas e saídas do reator&r."
				""
				"  Cada escotilha tem uma entrada, seja item ou fluido, e duas saídas. Os slots de entrada formarão uma grade, exibida no painel de controle do reator (acessível clicando com o botão direito no controlador)."
				""
				"  &6Cada escotilha tem uma temperatura&r e armazena calor que pode ser dissipado de várias maneiras. O calor se moverá naturalmente para uma escotilha adjacente ou para o exterior se a escotilha estiver na borda, embora isso fará com que o calor seja perdido. A velocidade deste processo é igual ao coeficiente de transferência de calor do conteúdo da escotilha, que pode ser encontrado no seu EMI, multiplicado pela diferença de temperatura. O calor também pode ser extraído em uma escotilha de fluido &bproduzindo vapor&r. &6Uma temperatura acima da temperatura máxima de um item irá destruí-lo&r."
				""
				"  Os elementos centrais do reator nuclear são &bnêutrons&r. Eles são produzidos pelo &bcombustível nuclear&r. Existem dois tipos de nêutrons, &brápidos&r e &btérmicos&r: os rápidos carregam energia enquanto os térmicos não. Nêutrons se movem em linha reta até encontrarem um elemento ou saírem do reator, embora para nêutrons rápidos, sua energia seja então perdida. O fluxo de nêutrons é mostrado no painel de controle do reator."
				""
				"  Quando um nêutron encontra uma escotilha não vazia, duas coisas podem acontecer, sendo o nêutron &babsorvido&r ou &bdisperso&r. &6Um nêutron disperso mudará aleatoriamente de direção&r. Se o nêutron disperso for rápido, ele tem chance de desacelerar, tornando-se térmico. Isso transfere a energia do nêutron para a escotilha na forma de calor. Um &6nêutron absorvido para seu curso e também transfere sua energia se fosse um nêutron rápido&r."
				""
				"  O número de nêutrons absorvidos em uma única escotilha pode ser visto no painel de controle. A probabilidade para cada processo é mostrada no seu EMI. Isso dependerá fortemente do conteúdo da escotilha e do tipo de nêutron, rápido ou térmico.&6 Combustíveis nucleares absorvem nêutrons térmicos muito melhor&r."
				""
				"  Quando um nêutron, rápido ou térmico, é absorvido em combustível nuclear, mais nêutrons são gerados. Esses são sempre nêutrons rápidos e têm direção aleatória. &6Sua geração é acompanhada pela liberação direta de energia na forma de calor adicional na escotilha&r."
				""
				"  Acima de um certo limite, o número de nêutrons gerados diminuirá com a temperatura até chegar a zero. &6Esse processo desperdiça alguma energia, mas garante a estabilidade do reator&r. O número de nêutrons gerados, eficiência efetiva, a energia direta e o limite de temperatura são todos mostrados no seu EMI."
				""
				"  Cada componente nuclear tem um número máximo de absorções. &6Quando alcançado, o item é destruído ou transformado em uma variante esgotada&r. Isso é particularmente útil para combustível nuclear porque alguma parte &6do &bU238&r &6é transformada em &bPlutônio&r &6em sua variante esgotada&r, significando que parte dele pode ser transformado de volta em combustível."
				""
				"  A mesma coisa acontece para fluidos, onde um pouco de fluido é transformado após cada absorção de nêutron. Isso pode ser usado para produzir em massa isótopos úteis como &bdeutério&r e &btrítio&r. Em ambos os casos, o resultado é mostrado no seu EMI."
			]
			old: [
				"  Honestamente, não posso culpá-lo. Embora, se você veio aqui depois de ter feito seu super reator incrível por curiosidade, eu o parabenizo. Mas para aqueles que precisavam de ajuda, por que não começamos? Preste atenção!"
				""
				"  O &bReator Nuclear&r pode produzir 100s de vezes mais EU/t do que o diesel. Ele vem em vários tamanhos, de &bpequeno&r a &bextremo&r."
				""
				"  Como ele funciona por baixo dos panos pode ser um pouco avassalador, no entanto, você não precisa entender os detalhes para conseguir projetar um reator poderoso."
				""
				"  &6Note que neste mundo, o &bReator Nuclear&r &6&onão pode&r &6explodir, emitir radiação ou danificar a área circundante&r. A única coisa que ele pode danificar são os itens que você coloca nele se a temperatura ficar muito alta, o que explicarei melhor mais tarde. Sinta-se à vontade para experimentar e aproveite sua nova vida como cientista nuclear!"
				""
				"  O componente principal é o &bRevestimento Nuclear&r, que é feito com &bLiga Nuclear&r; uma mistura de &bcádmio&r, &bberílio&r e &bliga à prova de explosão&r."
				""
				"  A parte superior da estrutura aceita &bEscotilhas de Item&r ou &bFluido Nuclear&r ou apenas revestimentos simples. &6Essas são as entradas e saídas do reator&r."
				""
				"  Cada escotilha tem uma entrada, seja de item ou fluido, e duas saídas. Os espaços de entrada formarão uma grade, exibida no painel de controle do reator (acessível clicando com o botão direito no controlador)."
				""
				"  &6Cada escotilha tem uma temperatura&r e armazena calor que pode ser dissipado de várias maneiras. O calor se moverá naturalmente para uma escotilha adjacente ou para o exterior se a escotilha estiver na borda, embora isso faça com que o calor seja perdido. A velocidade desse processo é igual ao coeficiente de transferência de calor do conteúdo da escotilha, que pode ser encontrado em seu EMI, multiplicado pela diferença de temperatura. O calor também pode ser extraído em uma escotilha de fluido &bproduzindo vapor&r. &6Uma temperatura acima da temperatura máxima de um item o destruirá&r."
				""
				"  Os elementos centrais do reator nuclear são os &bnêutrons&r. Eles são produzidos pelo &bcombustível nuclear&r. Existem dois tipos de nêutrons, &brápidos&r e &btérmicos&r: os rápidos carregam energia, enquanto os térmicos não. Os nêutrons se movem em linha reta até encontrarem um elemento ou saírem do reator, embora para nêutrons rápidos, sua energia seja então perdida. O fluxo de nêutrons é mostrado no painel de controle do reator."
				""
				"  Quando um nêutron encontra uma escotilha não vazia, duas coisas podem acontecer: o nêutron é &babsorvido&r ou &bespalhado&r. &6Um nêutron espalhado mudará de direção aleatoriamente&r. Se o nêutron espalhado for rápido, ele tem a chance de desacelerar, tornando-se um nêutron térmico. Isso transfere a energia do nêutron para a escotilha na forma de calor. Um &6nêutron absorvido para seu curso e também transfere sua energia se fosse um nêutron rápido&r."
				""
				"  O número de nêutrons absorvidos em uma única escotilha pode ser visto no painel de controle. A probabilidade de cada processo é mostrada em seu EMI. Isso dependerá fortemente do conteúdo da escotilha e do tipo de nêutron, rápido ou térmico.&6 Combustíveis nucleares absorvem nêutrons térmicos muito melhor&r."
				""
				"  Quando um nêutron, rápido ou térmico, é absorvido em combustível nuclear, mais nêutrons são gerados. Estes são sempre nêutrons rápidos e têm direção aleatória. &6Sua geração é acompanhada pela liberação direta de energia na forma de calor adicional na escotilha&r."
				""
				"  Acima de um certo limiar, o número de nêutrons gerados diminuirá com a temperatura até chegar a zero. &6Este processo desperdiça alguma energia, mas garante a estabilidade do reator&r. O número de nêutrons gerados, a eficiência efetiva, a energia direta e o limiar de temperatura são todos mostrados em seu EMI."
				""
				"  Cada componente nuclear tem um número máximo de absorções. &6Quando atingido, o item é destruído ou transformado em uma variante esgotada&r. Isso é particularmente útil para combustível nuclear porque parte do &6&bU238&r &6é transformada em &bPlutônio&r &6em sua variante esgotada&r, o que significa que parte dele pode ser transformada de volta em combustível."
				""
				"  O mesmo acontece com os fluidos, onde um pouco de fluido é transformado após cada absorção de nêutron. Isso pode ser usado para produzir em massa isótopos úteis como &bdeutério&r e &btrítio&r. Em ambos os casos, o resultado é mostrado em seu EMI."
			]
		}
		quest.37F3ABF113A1D399.quest_desc: {
			new: [
				"  A &bEscotilha de Entrada de Energia de BT&r é como uma entrada elétrica gigante. Como eu disse antes, você precisa de uma &bEscotilha de Entrada de Energia&r para alimentar máquinas multibloco elétricas."
				""
				"  Lembre-se de que você pode atualizar a máquina multibloco substituindo a &bEscotilha de Entrada de Energia&r por um nível aprimorado, aumentando a taxa máxima de energia para receitas e aumentando as capacidades gerais de overclock."
			]
			old: [
				"  A &bEscotilha de Entrada de Energia de BT&r é como uma tomada elétrica gigante. Como eu disse antes, você precisa de uma &bEscotilha de Entrada de Energia&r para alimentar máquinas elétricas multibloco."
