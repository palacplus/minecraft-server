		quest.325D7C592E2FB05A.quest_desc: {
			new: [
				"  O estado &bdefinitivo&r da matéria sólida, comprimido tão firmemente até ser um ponto de densidade e gravidade infinitas."
				""
				"  Embora você possa conter isso para usar em várias aplicações. Você está segurando... &bInfinito&r."
			]
			old: [
				"  O estado &búltimo&r da matéria sólida, comprimida tão firmemente até se tornar um ponto de densidade e gravidade infinitas."
				""
				"  No entanto, você pode conter isso para usá-lo em várias aplicações. Você está segurando... o &bInfinito&r."
			]
		}
		quest.4722157BC8D3B965.quest_desc: {
			new: [
				"  Um elegante revestimento de bronze com uma lâmina giratória viciosa dentro lhe dará &6proporções de corte ainda melhores&r do que você já experimentou usando seu &bMartelo de Forja&r. &aHora de parafusos, engrenagens, anéis e barras extras!&r"
				""
				"  Apenas lembre-se de que você não pode cortar de graça. Esta máquina funciona com &bVapor&r e usa &bLubrificante&r para fazer cortes limpos sem superaquecer. &bLubrificante&r pode ser produzido dentro do &bMisturador&r, usando &bRedstone&r e um dos vários hidrocarbonetos. Sugiro verificar os produtos do &bForno de Coque&r. Você pode encontrar algo para &6misturar&r com &bRedstone&r!"
			]
			old: [
				"  Um elegante revestimento de bronze com uma lâmina giratória viciosa dentro lhe dará &6taxas de corte ainda melhores&r do que você já experimentou usando seu &bMartelo de Forja&r. &aHora de parafusos, engrenagens, anéis e hastes extras!&r"
				""
				"  Apenas lembre-se que você não pode cortar de graça. Esta máquina funciona com &bVapor&r и usa &bLubrificante&r para fazer cortes limpos sem superaquecer. O &bLubrificante&r pode ser produzido dentro do &bMisturador&r, usando &bRedstone&r e um dos vários hidrocarbonetos. Sugiro dar uma olhada nos produtos do &bForno de Coque&r. Você pode encontrar algo para &6misturar&r com &bRedstone&r!"
			]
		}
		quest.791CAEBAE57EF0E1.quest_desc: {
			new: ["  &bMotores&r pegam eletricidade e produzem uma força rotacional. Você usará motores para criar muitas das máquinas e outros componentes no futuro. &6Você deve automatizar isso&r."]
			old: ["  &bMotores&r pegam eletricidade e produzem uma for00e7a rotacional. Voc00ea usar00e1 motores para criar muitas das m00e1quinas e outros componentes no futuro. &6Voc00ea deve automatiz00e1-los&r."]
		}
		quest.1CC910880728D896.quest_desc: {
			new: [
				"  Você se divertiu com a &bFissão Nuclear&r? Bem, é hora da &bFusão Nuclear&r!"
				""
				"  Em vez de dividir um núcleo pesado e instável em dois núcleos mais leves, a &bfusão&r combinará dois núcleos leves, o que, por sua vez, libera grandes quantidades de energia."
				""
				"  Essa energia pode ser contida e usada para produzir &bPlasma de Hélio&r, um fluido extremamente denso em energia que pode ser usado como a melhor fonte de energia do mundo."
				""
				"  Você pode combinar combustíveis gasosos como &bDeutério&r, &bTrítio&r e/ou &bHélio-3&r para produzir várias combinações de Plasma de Hélio, Trítio, Deutério e Hidrogênio."
				""
				"  Tenha em mente, esta fusão consome muita energia para começar, mas pode produzir muito mais como resultado."
			]
			old: [
				"  Você se divertiu com a &bFissão Nuclear&r? Bem, é hora da &bFusão Nuclear&r!"
				""
				"  Em vez de dividir um núcleo pesado e instável em dois núcleos mais leves, a &bfusão&r combinará dois núcleos leves, o que, por sua vez, libera vastas quantidades de energia."
				""
				"  Essa energia pode ser contida и usada para produzir &bPlasma de Hélio&r, um fluido extremamente denso em energia que pode ser usado como a melhor fonte de energia do mundo."
				""
				"  Você pode combinar combustíveis gasosos como &bDeutério&r, &bTrítio&r e/ou &bHélio-3&r para produzir várias combinações de Plasma de Hélio, Trítio, Deutério e Hidrogênio."
				""
				"  Tenha em mente, esta fusão requer muita energia para começar, mas pode produzir muito mais como resultado."
			]
		}
		quest.1CA2825FFA775BBE.quest_desc: {
			new: [
				"  Esta é uma nova máquina elétrica que usa fortes correntes elétricas para dividir materiais em diferentes partes."
				""
				"  Mais notavelmente, você pode &6dividir &bÁgua&r &6em seus dois componentes principais: &bHidrogênio&r &6e &bOxigênio&r."
				""
				"  Este processo é chamado de &6 Eletrólise&r e funciona usando corrente elétrica para dividir ||compostos iônicos|| em seus elementos."
			]
			old: [
				"  Esta é uma nova máquina elétrica que usa fortes correntes elétricas para dividir materiais em diferentes partes."
				""
				"  Mais notavelmente, você pode &6dividir &bÁgua&r &6em seus dois componentes principais: &bHidrogênio&r &6e &bOxigênio&r."
