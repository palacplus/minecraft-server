		quest.164F4710E109F7F2.quest_desc: {
			new: [
				"  Hora daquela &bBarra Laranja&r brilhante? Você precisará pegar um pouco do pó de &bCobre&r e &bEstanho&r que você obtém do &bMartelo de Forja&r para fazê-la. É uma mistura simples de &63:1&r de &bCobre&r para &bEstanho&r na sua grade de criação. Uma vez que você &6progrida&r, encontrará uma maneira de produzir essa mistura de forma mais &6eficiente&r, já que está derramando algum &bpó&r fazendo isso à mão."
				""
				"  Agora que você está entrando na &aEra do Vapor&r com este &bBronze&r, darei algumas &6dicas&r sobre as &bmáquinas&r que você estará fazendo. Lembre-se de que &bMáquinas a Vapor&r aceitarão entradas de &6qualquer lado&r, sejam &b itens, vapor ou outro fluido&r. Você pode &6trancar&r seus slots &6clicando&r no botão que parece um &bcadeado&r na &binterface&r. "
				""
				"&6Trancar&r slots garantirá que a máquina aceite &6apenas&r um tipo de &bitem&r ou &bfluido&r por slot."
				""
				"  Toda &bmáquina&r tem um &blado de saída&r também, e você pode &6ativar&r a &bsaída automática&b de dentro da &rinterface&r. Usando sua fiel &bChave Inglesa&r você pode &6ajustar&r o lado de saída com facilidade!"
				""
				"  Se você não quer tantos &bitens&r nos slots de uma vez, &6use&r essa &bRoda de Rolagem&r sua para &6ajustar&r o número máximo de &bitens&r armazenados de cada vez."
				""
				"  &cP.S.&r Clicar com o botão direito em uma &bmáquina a vapor&r com &7pólvora&r dobrará sua &6velocidade&r e &6consumo de vapor&r. Tenha isso em mente ao olhar as receitas. Aquela &7pólvora&r pode apenas te poupar uma viagem ao inferno."
			]
			old: [
				"  Hora daquela &bBarra Laranja&r lindamente brilhante? Você precisará pegar um pouco do pó de &bCobre&r e &bEstanho&r que você obtém do &bMartelo de Forja&r para fazê-la. É uma mistura simples de &63:1&r de &bCobre&r para &bEstanho&r na sua grade de criação. Uma vez que você &6progredir&r, encontrará uma maneira de produzir essa mistura de forma mais &6eficiente&r, já que está derramando um pouco de &bpó&r ao fazê-la manualmente."
				""
				"  Agora que você está entrando na &aEra do Vapor&r com este &bBronze&r, vou lhe dar algumas &6dicas&r sobre as &bmáquinas&r que você fará. Lembre-se que as &bMáquinas a Vapor&r aceitarão entradas de &6qualquer lado&r, seja &bitens, vapor ou outro fluido&r. Você pode &6travar&r seus slots &6clicando&r no botão que parece um &bcadeado&r na &binterface&r. "
				""
				"Slots &6travados&r garantirão que a máquina &6só&r aceite um tipo de &bitem&r ou &bfluido&r por slot."
				""
				"  Toda &bmáquina&r tem um &blado de saída&r também, e você pode &6ativar&r a &bsaída automática&b de dentro da &rinterface&r. Usando sua fiel &bChave Inglesa&r, você pode &6ajustar&r o lado de saída com facilidade!"
				""
				"  Se você não quiser tantos &bitens&r nos slots de uma vez, &6use&r sua &bRoda do Mouse&r para &6ajustar&r o número máximo de &bitens&r armazenados de uma vez."
				""
				"  &cP.S.&r Clicar com o botão direito em uma &bmáquina a vapor&r com &7pólvora&r dobrará sua &6velocidade&r e &6consumo de vapor&r. Lembre-se disso ao olhar as receitas. Aquela &7pólvora&r pode te salvar de uma viagem ao inferno."
			]
		}
		quest.2F66F85A601AC908.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
				"  Agora você pode &6hemiquadruplicar seus minérios&r! Isso significa que você terá 50% de chance de extrair um pó extra do seu &bMinério Bruto&r. Você também pode pegar um &bMinério Completo&r e extrair muito &bMinério Bruto&r dele usando o &bMacerador&r."
				""
				"  Sendo um &bMacerador&r, você pode jogar alguns itens de metal para &6reciclá-los de volta em pós&r, uma boa maneira de obter um pouco de uma viagem de aventura ou uma ferramenta velha."
			]
			old: [
				"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
				"  Agora você pode &6hemiquadruplicar seus minérios&r! Isso significa que você terá 50% de chance de extrair um pó extra do seu &bMinério Bruto&r. Você também pode transformar um &bMinério Completo&r e extrair muito &bMinério Bruto&r dele usando o &bMacerador&r."
				""
				"  Sendo um &bMacerador&r, você pode jogar alguns itens de metal para &6reciclá-los de volta em pós&r, uma boa maneira de obter um pouco de retorno de uma viagem de aventura ou de uma ferramenta antiga."
			]
		}
		quest.6F63B60042A7F6AE.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/compressor/overlay_front_active width:32 height:32 align:center}"
				"  Este é o &bCompressor&r e provavelmente a primeira máquina que você vai querer construir. Ser capaz de &6transformar barras em chapas&r em uma proporção de 1:1 é extremamente útil durante a era do vapor."
				""
				"  Você economiza recursos e não precisará queimar martelos apenas para coletar chapas suficientes para seu primeiro projeto."
				""
				"  Ele também pode pegar aquelas &bBarras Duplas&r que você pode empilhar com o martelo de forja em &o2&r chapas, economizando vapor e tempo."
			]
			old: [
				"{image:modern_industrialization:block/machines/compressor/overlay_front_active width:32 height:32 align:center}"
				"  Este 00e9 o &bCompressor&r e provavelmente a primeira m00e1quina que voc00ea vai querer construir. Ser capaz de &6transformar barras em chapas&r na propor00e700e3o de 1:1 00e9 extremamente 00fatil durante a era do vapor."
				""
				"  Voc00ea economiza recursos e n00e3o precisar00e1 gastar martelos apenas para coletar chapas suficientes para o seu primeiro projeto."
				""
				"  Ele tamb00e9m pode pegar aquelas &bBarras Duplas&r que voc00ea pode empilhar com o martelo de forja em &o2&r chapas, economizando vapor e tempo."
			]
		}
		quest.3761B64135EA94C0.quest_subtitle: {
			new: "Isso é Sr. Fusão para Você!"
			old: "Para Você, é Senhor Fusão!"
		}
		quest.707EBB99AA8F4C57.quest_desc: {
			new: [
				"  Hora de fazer seu primeiro fio; longas cordas de metais altamente condutores para a transferência de eletricidade. &6Você pode combinar esses fios simples com suas &bFolhas de Borracha&r &6para fazer &bCabos&r. "
				""
				"  Certifique-se de colocar borracha suficiente em volta desses fios, não vai querer levar um choque!"
			]
			old: [
				"  Hora de fazer seu primeiro fio; longos fios de metais altamente condutores para a transfer00eancia de eletricidade. &6Voc00ea pode combinar esses fios simples com suas &bFolhas de Borracha&r &6para fazer &bCabos&r."
				""
				"  Certifique-se de colocar borracha suficiente ao redor desses fios, n00e3o quer levar um choque!"
			]
		}
		quest.74C5FDC3B1E74586.quest_desc: {
			new: [
				"O &bTransformador de Fluxo&r é uma máquina poderosa que permite praticamente &6multiplicar&r o tipo de energia chamado &eEU&r na energia de &eFE&r. É tão poderoso, de fato, que &6multiplica&r a saída de energia por &a50&r (5x mais que o padrão)!"
				""
				"Tenha em mente, você não pode fazer um loop da &aenergia&r de volta, é um processo de &cvia única&r."
			]
			old: [
				"O &bTransformador de Fluxo&r 00e9 uma m00e1quina poderosa que permite praticamente &6multiplicar&r o tipo de energia chamado &eEU&r na energia de &eFE&r. 00c9 t00e3o poderoso que &6multiplica&r a sa00edda de energia por &a50&r (5x mais que o padr00e3o)!"
				""
				"Tenha em mente, voc00ea n00e3o pode criar um loop de &aenergia&r, 00e9 um processo de &cm00e3o-00fanica&r."
			]
		}
		quest.16AAEB122CDC1A46.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/mixer/overlay_top_active width:32 height:32 align:center}"
				"  Um elegante Revestimento de bronze com uma tigela de metal brilhante onde lâminas de mistura são baixadas para &6misturar&r uma infinidade de coisas diferentes! Você pode &6misturar pós&r com uma saída maior, já que não estará derramando nada."
				""
				"  Ele não mistura apenas pós, mas também fluidos. Exemplo: &eLubrificante&r!"
			]
			old: [
				"{image:modern_industrialization:block/machines/mixer/overlay_top_active width:32 height:32 align:center}"
				"  Uma elegante Carcaça de bronze com uma tigela de metal brilhante onde as lâminas de mistura são baixadas para &6misturar&r uma infinidade de coisas diferentes! Você pode &6misturar pós&r com uma produção maior, já que não derramará mais nada."
				""
				"  Não mistura apenas pós, mas também fluidos. Exemplo: &eLubrificante&r!"
			]
		}
		quest.58CA2853D9620919.quest_desc: {
			new: [
				"A &bMelhoria Básica&f é uma melhoria que você pode &6criar&f apenas com componentes simples para &9acelerar&f suas máquinas."
