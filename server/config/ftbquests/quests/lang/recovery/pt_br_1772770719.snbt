	"chapters/Irons Spells.snbt": {
		quest.37A5C2FCA8F75BE6.title: {
			new: "Troque com o Sacerdote"
			old: "Trocar com o papa"
		}
		quest.43ACFDB5CD949C74.quest_desc: {
			new: ["Usando a Forja de Pergaminhos e uma Batata Venenosa para fazer um Pergaminho da Natureza, que é bom para dano de Veneno ou manter os inimigos enraizados no lugar."]
			old: ["Use a Forja de Pergaminhos e uma Batata Venenosa para fazer Pergaminhos da Natureza, que são bons para dano de Veneno ou para manter os inimigos enraizados no lugar."]
		}
		quest.3D4317C2B25D5680.quest_desc: {
			new: [
				"A &bForja de Pergaminhos&r é usada para &6criar&r pergaminhos usando &bPapel&r e &bTinta&r."
				""
				"Existem diferentes tipos de &bfeitiços&r que você pode criar com diferentes itens. "
				""
				"Esses diferentes itens são referidos como &bFocos&r. "
				""
				"Cada &bFoco&r é usado para uma variedade específica de pergaminhos. "
				""
				"Saiba que dependendo do &6Nível&r da &bTinta&r que você escolher, pergaminhos mais raros estarão disponíveis, e o pergaminho será mais poderoso."
			]
			old: [
				"A &bForja de Pergaminhos&r é usada para &6criar&r pergaminhos usando &bPapel&r e &bTinta&r."
				""
				"Existem diferentes tipos de &bfeitiços&r que você pode criar com diferentes itens."
				""
				"Esses diferentes itens são referidos como &bFocos&r."
				""
				"Cada &bFoco&r é usado para uma variedade específica de pergaminhos."
				""
				"Saiba que, dependendo do &6Nível&r da &bTinta&r que você escolher, os pergaminhos mais raros estarão disponíveis, e o pergaminho será mais poderoso."
			]
		}
		quest.7422BD3C0F060AC5.title: {
			new: "Livros de Feitiços Mágicos"
			old: "Livros de Feiti00e7os de Mago"
		}
		quest.0696635896D223CA.quest_desc: {
			new: ["O Cajado do Barba-Cinza fará exatamente isso, te dar uma Barba-Cinza... Brincadeira, este cajado ajudará você a regenerar mana, bem como aumentar o poder do seu pergaminho. Este é um dos cajados mais fáceis de criar."]
			old: ["O Cajado do Barba-cinzenta fará exatamente isso, lhe dará um Barba-cinzenta... Brincadeira, este cajado o ajudará a regenerar mana, bem como a aumentar o poder do seu pergaminho. Este é um dos cajados mais fáceis de criar."]
		}
		quest.480F170F7028C337.quest_desc: {
			new: ["O slot de Feitiço Inferior "]
			old: ["O espaço de Feitiço Menor "]
		}
		task.1ACF33BDD92D15DA.title: {
			new: "MATE o Sacerdote"
			old: "MATE o Papa"
		}
		quest.74D9B681E8EFE064.quest_desc: {
			new: ["Pérolas do Ender são deixadas por endermen e são usadas para criar Pergaminhos do Ender."]
			old: ["P00e9rolas do Ender s00e3o dropadas por endermen e s00e3o usadas para criar Pergaminhos do Ender."]
		}
		quest.7CF09238E123231F.quest_desc: {
			new: [
				"A &bVara de Raios&r dá a você &a+15%&r de &9Redução de Tempo de Recarga de Feitiço&r e &ePoder de Feitiço de Raio&r, ela também dá &a5%&r de poder de pergaminho para &bPergaminhos&r que não sejam de raio. "
				""
				"Use isso para ajudar a lançar feitiços com mais eficiência."
			]
			old: [
				"A &bVara do Rel00e2mpago&r lhe d00e1 um &a+15%&r de &9Redu00e700e3o de Recarga de Feiti00e7o&r e &ePoder de Feiti00e7o de Rel00e2mpago&r, ela tamb00e9m d00e1 um &a5%&r de poder de pergaminho para &bPergaminhos&r que n00e3o s00e3o de rel00e2mpago."
				""
				"Use isso para ajudar a lan00e7ar feiti00e7os com mais efici00eancia."
			]
		}
		quest.2F53567C34E86536.quest_desc: {
			new: ["Este é o Livro de Feitiços mais básico, ele pode conter apenas cinco Feitiços"]
			old: ["Este é o Livro de Feitiços mais básico, ele só pode conter cinco Feitiços"]
		}
		quest.69400E62D67A21FC.quest_desc: {
			new: ["Usando uma Forja de Pergaminhos e uma Esmeralda, crie um Pergaminho de Evocação."]
			old: ["Usando uma Forja de Pergaminho e uma Esmeralda, crie um Pergaminho de Evoca00e700e3o."]
		}
		quest.28724CA9F837F710.quest_desc: {
			new: ["Amuleto de Ressonância de Ametista - quando usado, este amuleto concederá a você um aumento de 15% na regeneração de mana."]
			old: ["Amuleto de Ressonância de Ametista - quando usado, este amuleto concederá um aumento de 15% na regeneração de mana."]
		}
		quest.3B3FDF02E891DD39.quest_desc: {
			new: ["O Livro de Feitiços de Aprendiz, sendo um livro melhor, requer que você faça uma viagem ao Nether."]
			old: ["O Livro de Feitiços do Aprendiz, sendo um livro melhor, exige que você faça uma viagem ao Nether."]
		}
		quest.3E212B5DE277B73A.quest_subtitle: {
			new: "Oink Oink"
			old: "Oinc Oinc"
		}
		quest.67792A4DE6EDBC37.quest_desc: {
			new: ["O Manuscrito Eldritch é feito com Oito Fragmentos de Conhecimento e um Fragmento de Eco. Ambos são encontrados ao saquear Cidades Ancestrais. Ao usar, ele lhe dará o poder de um Pergaminho Eldritch que você escolher. Você pode desbloquear mais, mas um novo Manuscrito é necessário por pergaminho."]
			old: ["O Manuscrito Eldritch é feito com Oito Fragmentos de Conhecimento e um Caco de Eco. Ambos são encontrados ao saquear Cidades Antigas. Ao ser usado, ele lhe dará o poder de um Pergaminho Eldritch que você escolher. Você pode desbloquear mais, mas um novo Manuscrito é necessário por pergaminho."]
		}
		quest.0C37E9D8A7823264.quest_desc: {
			new: ["A Bengala do Artífice ajuda a caminhar para todos vocês velhinhos - de novo, brincadeira. Este cajado dará uma redução no tempo de recarga e tempo de lançamento e aumentará seu poder de feitiço. Este é um pouco mais caro que o cajado do Barba-Cinza, no entanto, vale a pena para lançar feitiços maiores (Faça desses cajados algo único)."]
			old: ["A Bengala do Artífice ajuda a andar para todos vocês, velhinhos - de novo, brincadeira, este cajado dará uma redução no tempo de recarga e de conjuração e aumentará o poder do seu feitiço. Este é um pouco mais caro que o cajado do Barba-cinzenta, no entanto, vale a pena para conjurar feitiços maiores (faça desses cajados algo próprio)."]
		}
		quest.5F2801445E518E49.quest_desc: {
			new: ["Frascos de Sangue são obtidos ficando em um Caldeirão de Alquimista ou ficando em um Caldeirão normal com fogo embaixo dele. Uma vez que ele encher com um pouco de sangue, você pode clicar com o botão direito com um frasco vazio para coletar o sangue."]
			old: ["Frascos de Sangue são obtidos ao ficar em um Caldeirão do Alquimista ou em um Caldeirão normal com fogo embaixo. Assim que encher com um pouco de sangue, você pode Clicar com o Botão Direito com uma garrafa vazia para coletar o sangue."]
		}
		quest.71A219DF9715D153.quest_desc: {
			new: ["Usando a Forja de Pergaminhos e um Osso Congelado para criar um Pergaminho de Gelo."]
			old: ["Usando a Forja de Pergaminho e um Osso Congelado para criar um Pergaminho de Gelo."]
		}
		quest.51A8026A0F8A83B1.quest_desc: {
			new: ["Esmeraldas podem ser encontradas minerando, explorando ou trocando com aldeões e são usadas para criar os Pergaminhos de Evocação."]
			old: ["Esmeraldas podem ser encontradas enquanto minera, explora ou troca com aldeões e são usadas para criar os Pergaminhos de Evocação."]
		}
		quest.573FAED7B35F6C86.quest_desc: {
			new: ["Para o mago mais experiente, o Livro de Feitiços Encantado tem dez slots."]
			old: ["Para o mago mais experiente, o Livro de Feitiços Encantado tem dez espaços."]
		}
		quest.5F8E418D6A0AD158.quest_desc: {
			new: ["Pérolas Divinas são criadas usando uma Barra de Ouro e um Fragmento de Ametista em uma Bancada de Trabalho. Elas são usadas para criar Pergaminhos Sagrados."]
			old: ["Pérolas Divinas são criadas com uma Barra de Ouro e um Caco de Ametista em uma Bancada de Trabalho. Elas são usadas para criar Pergaminhos Sagrados."]
		}
		quest.3AAE23B6BE07E5DC.quest_desc: {
			new: ["Usando a Forja de Pergaminhos e uma Pérola Divina para criar um Pergaminho Sagrado, que é bom para cura e efeitos."]
			old: ["Usando a Forja de Pergaminhos e uma Pérola Divina para criar Pergaminhos Sagrados que são bons para cura e efeitos."]
		}
		quest.77719A9FBDFE49A7.quest_desc: {
			new: ["Assim que você obtiver uma pedra rúnica em branco, você pode criar uma que seja infundida com o poder de diferentes tipos de magia. Estas são usadas para criar melhorias para seu equipamento ou apenas equipamentos melhores em geral"]
			old: ["Depois de obter uma Pedra R00fanica em branco, voc00ea pode criar uma que seja infundida com o poder de diferentes tipos de magia. Elas s00e3o usadas para criar melhorias para seu equipamento ou apenas equipamentos melhores em geral"]
		}
		quest.33EEBDD0730C020E.quest_desc: {
			new: ["Usando a Forja de Pergaminhos e um Frasco de Sangue para criar um Pergaminho de Sangue."]
			old: ["Usando a Forja de Pergaminhos e um Frasco de Sangue para criar Pergaminhos de Sangue."]
		}
		quest.5221657F939FE63B.quest_desc: {
			new: ["Use a Forja de Pergaminhos e um Frasco de Raios para criar um Pergaminho de Raios."]
			old: ["Use a Forja de Pergaminhos e uma Garrafa com Relâmpago para criar Pergaminhos de Relâmpago."]
		}
		quest.0ED5CB1120D1BD6E.quest_desc: {
			new: ["Encontrados enquanto explora, os Pergaminhos são achados por todo o mundo, mas se você não for cuidadoso e decidir usar o Pergaminho, ele terá apenas um uso."]
			old: ["Encontrados durante a exploração, os Pergaminhos são encontrados por todo o mundo, mas se você não for cuidadoso e optar por usar o Pergaminho, ele terá apenas um uso."]
		}
		quest.6D092A4BC4A22314.quest_desc: {
			new: ["Fragmentos de Conhecimento Ancestral podem ser encontrados raramente em espólios de estantes de livros, mais comumente encontrados em Cidades Ancestrais ou trocando com um Vendedor Ambulante. Estes são usados para Criar um Manuscrito Eldritch, que é a chave para desbloquear o Conhecimento Ancestral que foi perdido há muito, muito tempo e agora é visto apenas sendo usado por Wardens e os poucos que ousam ir procurar por essa velha escola de magia."]
			old: ["Fragmentos de Conhecimento Antigo podem ser encontrados raramente em saques de estantes de livros, mais comumente encontrados em Cidades Antigas ou trocando com um Vendedor Ambulante. Eles s00e3o usados para criar um Manuscrito Elditch, que 00e9 a chave para desbloquear o Conhecimento Antigo que foi perdido h00e1 muito, muito tempo e agora s00f3 00e9 visto sendo usado por Wardens e pelos poucos que ousam procurar por essa antiga escola de magia."]
		}
		quest.7422BD3C0F060AC5.quest_desc: {
			new: ["Estes são os livros de feitiços de nível mais alto que um mago experiente pode Obter"]
			old: ["Estes s00e3o os livros de feiti00e7os de mais alto n00edvel que um mago experiente pode obter"]
		}
		quest.3E8C6BD8557C6F08.quest_desc: {
			new: [
				"Depois de usar o Manuscrito para desbloquear um Pergaminho Eldritch, você pode usar um Fragmento de Eco na Forja de Pergaminhos para criar um Feitiço Eldritch. Esses Pergaminhos só podem ser criados com Tinta Lendária."
				""
				"Manto Abissal - Já desejou poder apenas esquivar de ataques? Creeper explode e você apenas diz \"Haha, não me acertou\"? Com este feitiço você se transforma em um enderman, teletransportando-se para longe quando for atacado, virtualmente invencível enquanto o feitiço durar."
				""
				"Explosão Eldritch - Uma vez ativado, você pode disparar até 7 explosões de pura energia. Cada tiro pode disparar a até 30 blocos de distância, apenas certifique-se de não explodir sua própria cabeça."
				""
				"Visão Planar - Este parece trapaça... você pode ver qualquer entidade dentro da distância de renderização permitida. Sim, funciona com entidades invisíveis e visíveis e as faz brilhar através das paredes."
				""
				"Tentáculos de Sculk - Este é um feitiço muito perturbador que libera uma floresta de Tentáculos de Sculk do chão, ótimo para pregar peças em amigos que são novos no jogo ou acabar com grupos de mobs, e causa uma quantidade decente de dano."
				""
				"Estrondo Sônico - Torne-se um Warden e libere um estrondo que causa muito dano a entidades dentro de um alcance de 20-30 blocos (dependendo do nível)."
				""
				"Telecinesia - Já teve um mob ou amigo que você só queria arremessar no esquecimento? Com este feitiço você pode pegar uma entidade e arremessá-la até o feitiço acabar. Cuidado, porém, se você fazê-los bater em uma parede, eles sofrerão dano cinético."
			]
			old: [
				"Depois de usar o Manuscrito para desbloquear um Pergaminho Eldritch, você pode usar um Fragmento de Eco na forja de Pergaminhos para criar um Feitiço Eldritch. Estes Pergaminhos só podem ser criados com Tinta Lendária."
				""
				"Manto Abissal - Já desejou poder simplesmente evitar ataques? Um Creeper explode e você simplesmente diz \"Haha errou\"? Com este feitiço você se transforma em um enderman, teletransportando-se para longe quando é atacado, virtualmente invencível enquanto o feitiço durar."
				""
				"Explosão Eldritch - Uma vez ativado, você pode disparar até 7 explosões de energia pura. Cada tiro pode ir até 30 blocos de distância, só tome cuidado para não explodir sua própria cabeça."
				""
				"Visão Planar - Este parece trapaça... você pode ver qualquer entidade dentro da distância de renderização permitida. Sim, funciona com entidades invisíveis e visíveis e as faz brilhar através das paredes."
				""
				"Tentáculos de Skulk - Este é um feitiço muito perturbador que libera uma floresta de Tentáculos de Skulk do chão, ótimo para pregar peças em amigos que são novos no jogo ou para eliminar grupos de mobs, e causa uma quantidade decente de dano."
				""
				"Estrondo Sônico - Torne-se um Warden e libere um estrondo que causa muito dano a entidades dentro de um alcance de 20-30 blocos (dependendo do nível)."
				""
				"Telecinese - Já teve um mob ou amigo que você só quer arremessar para o esquecimento? Com este feitiço você pode pegar uma entidade e arremessá-la por aí até o feitiço acabar. Cuidado, porém, se você fazê-los bater em uma parede, eles sofrerão dano cinético."
			]
		}
		quest.704C0B04EFF5024C.quest_desc: {
			new: [
				"Esta Mesa é usada para compilar &bPergaminhos &fque você encontrou e criou em um &bLivro de Feitiços&f."
