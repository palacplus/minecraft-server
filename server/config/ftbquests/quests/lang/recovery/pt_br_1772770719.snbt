		quest.3F0097CCBA02804C.quest_desc: {
			new: ["A &bFornalha a Vapor Grande&r pode &6fundir&r receitas em lotes de até 8 com uma dedução de &a25%&r no custo de &eEU&r. Tenha em mente, ela &cnão&r fará uma mistura de receitas, elas &odevem&r ser do mesmo tipo. Se não, cada tipo de receita será &6dividido&r em seu lote de no máximo 8."]
