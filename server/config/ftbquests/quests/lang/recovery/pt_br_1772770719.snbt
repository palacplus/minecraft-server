		quest.4E062B9B4960632D.quest_desc: {
			new: [
				"Transporte adequado movido a combustível... e acomoda dois!"
				""
				"Tem espaço de armazenamento decente, três espaços para melhorias, um espaço para arma, um espaço para estandarte e um espaço para corante também — para colorir o nariz dianteiro e a cauda traseira."
			]
			old: [
				"Transporte adequado, a combustível... e com assentos para dois!"
				""
				"Tem espaço de armazenamento decente, três espaços para melhorias, um espaço para arma, um espaço para estandarte e um espaço para corante também—para colorir o nariz dianteiro e a cauda traseira."
			]
		}
		quest.217C5C65AFC95842.quest_desc: {
			new: [
				"Pequeno e bom para trabalhar fora do chão... construindo, minerando o teto de uma caverna, etc."
				""
				"Queima combustível, tem um espaço para melhoria, um espaço para arma e algum espaço de armazenamento."
			]
			old: [
				"Pequeno e bom para trabalhar fora do chão... construir, minerar o teto de uma caverna, etc."
				""
				"Queima combustível, tem um slot de melhoria, um slot de arma e algum espaço de armazenamento."
			]
		}
