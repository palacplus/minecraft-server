		quest.0B98E8AC5CFB0FC2.quest_desc: {
			new: ["Obtido quando você deixa seus&b Agregados Entroizados &acrescerem&f até o &aestágio máximo&f."]
			old: ["Obtido quando você deixa seus&b Aglomerados Entroizados &acrescerem&f até o &aestágio máximo&f."]
		}
		quest.3B82F8F19AF630D5.quest_desc: {
			new: ["O&b Ponto de Alternância &fé o mesmo que um &bCabo de Vidro&f, mas é usado para &6desativar temporariamente&f a seção de um sistema a jusante dele quando sem energia. &6Alimentá-lo&f permitirá que dados e energia passem mais uma vez."]
			old: ["O&b Barramento de Alternância &fé o mesmo que um &bCabo de Vidro&f, mas é usado para &6desativar temporariamente&f a seção de um sistema a jusante dele quando não energizado. &6Energizá-lo&f permitirá que dados e energia passem novamente."]
		}
		quest.7C201074DDBAE831.quest_desc: {
			new: ["Eu acho que todo aquele bioma poderia desaparecer no seu &bArmazenamento ME..."]
			old: ["Acho que aquele bioma inteiro poderia desaparecer no seu &bArmazenamento ME..."]
		}
		quest.3E165961635B0C4B.quest_desc: {
			new: ["Um &6Meteorito&r sempre conterá um &bCubo Misterioso&r. Assim que encontrar um &bCubo Misterioso&f, você deve quebrá-lo para obter todas as &bPrensas do Inscritor&f."]
			old: ["Um &6Meteorito&r sempre conterá um &bCubo Misterioso&r. Uma vez que você encontre um &bCubo Misterioso&f, você deve quebrá-lo para obter todas as &bPrensas de Inscrição&f."]
		}
		quest.62FCB2F06126B622.quest_desc: {
			new: ["O &bTerminal Sem Fio&f é um &bTerminal regular&f que pode ser usado para acessar um&b Sistema ME&b sem fio. Use um &bPonto de Acesso&f para conectar seu &bTerminal&f e use &bCartões de Reforço&b para aumentar a distância total desse &bPonto de Acesso&f que você quer ser capaz de usar seu sistema. Usar múltiplos &bPontos de Acesso&f na mesma rede em locais diferentes pode ajudar você a cobrir uma área maior."]
			old: ["O &bTerminal Sem Fio&f é um &bTerminal regular&f que pode ser usado para acessar um&b Sistema ME&b sem fio. Use um &bPonto de Acesso&f para conectar seu &bTerminal&f e use &bCartões de Reforço&b para aumentar a distância total daquele &bPonto de Acesso&f que você deseja poder usar seu sistema. Usar múltiplos &bPontos de Acesso&f na mesma rede em locais diferentes pode ajudá-lo a cobrir uma área maior."]
		}
		quest.6DFA92E319E7DA77.title: {
			new: "Provedor de Padrão"
			old: "Fornecedor de Moldes"
		}
		quest.59128813386BFDB1.quest_desc: {
			new: [
				"&bTúneis Ponto a Ponto (P2P)&f podem ser esmagadoramente complexos, mas ao mesmo tempo extremamente úteis. Estes &btúneis&f podem ser usados para &6transferir até 32 canais de um ponto para o outro&f. Agora, você pode estar perguntando: \"Mas por que não posso simplesmente usar um &bCabo Denso&f?\""
				""
				"E eu estou aqui para dizer, você pode! Mas é &6terrivelmente ineficiente&f. Esses 32 canais são compactados em um único canal. Isso significa que você pode teoricamente conectar &61.024 canais&f através de um &6único cabo denso, em vez de apenas 32&f."
				""
				"Você terá que usar o &bCartão de Memória&f para &6vincular&f os &btúneis&f juntos via frequências. &6Shift-Clique Direito &fno &btúnel de \"entrada\" &bdefinirá o &bcartão de memória &fpara essa frequência. &6Clicar com o botão direito&f no &btúnel de \"saída\" &fdefinirá o&b túnel &fpara a frequência do&b \"entrada\"&f. Tenha em mente que você pode ter múltiplos &btúneis de \"saída\"&f contanto que o total de canais usados entre eles não vá além do número de canais inseridos no&b túnel de \"entrada\"&f."
				""
				"Existem também diferentes tipos de&b Túneis Ponto a Ponto&f. Além de um que carrega &bCanais ME&f, existem aqueles que &6transferem &benergia bruta&f, &bfluidos&f, &bitens&f,&b luz&f, e até&b redstone&f! Eles funcionam da mesma maneira, além de &bcarregar canais&f."
				""
				"Leva algum tempo de prática para usar, então experimente com eles primeiro. Assim que pegar o jeito, seu &bSistema ME&f parecerá mais do que profissional!"
			]
			old: [
				"Os &bTúneis Ponto a Ponto (P2P)&f podem ser esmagadoramente complexos, mas ao mesmo tempo extremamente úteis. Esses &btúneis&f podem ser usados para &6transferir até 32 canais de um ponto para outro&f. Agora, você pode estar se perguntando: \"Mas por que não posso simplesmente usar um &bCabo Denso&f?\""
				""
				"E estou aqui para dizer, você pode! Mas é &6extremamente ineficiente&f. Esses 32 canais são compactados em um único canal. Isso significa que, teoricamente, você pode conectar &61.024 canais&f através de um &6único cabo denso, em vez de apenas 32&f."
				""
				"Você terá que usar o &bCartão de Memória&f para &6conectar&f os &btúneis&f através de frequências. &6Shift-Clique-Direito &fno túnel de &b\"entrada\" &bdefinirá o &bcartão de memória &fpara essa frequência. &6Clique-Direito&f no túnel de &b\"saída\" &fdefinirá o&b túnel &fpara a frequência do de&b \"entrada\"&f. Lembre-se, você pode ter múltiplos túneis de &b\"saída\"&f, desde que o total de canais usados entre eles não ultrapasse o número de canais inseridos no túnel de&b \"entrada\"&f."
				""
				"Existem também diferentes tipos de&b Túneis Ponto a Ponto&f. Além de um que transporta &bCanais ME&f, existem aqueles que &6transferem &benergia bruta&f, &bfluidos&f, &bitens&f,&b luz&f, e até&b redstone&f! Eles funcionam da mesma forma, exceto por &btransportar canais&f."
				""
				"Leva um pouco de prática para usar, então experimente-os primeiro. Quando você pegar o jeito, seu &bSistema ME&f parecerá mais do que profissional!"
			]
		}
