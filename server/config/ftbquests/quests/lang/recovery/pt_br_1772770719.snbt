	"chapters/Immersive Aircraft.snbt": {
		quest.16F37A3E31EBDA50.quest_desc: {
			new: [
				"Monolugar rápido, exige mais esforço para pilotar, mas é muito divertido, cara!"
				""
				"Tem algum espaço de armazenamento, um espaço para arma, quatro espaços para melhorias, um espaço para estandarte, e pode até levar foguetes para impulsionar!"
			]
			old: [
				"Monoposto rápido, exige mais esforço para pilotar, mas é muito divertido, colega!"
				""
				"Possui algum espaço de armazenamento, um slot de arma, quatro slots de melhoria, um slot de estandarte e pode até usar foguetes para impulso!"
			]
		}
		quest.5A5583EA02C78372.quest_desc: {
			new: [
				"Um dirigível aprimorado, com muito espaço de armazenamento."
				""
				"Bom para transportar cargas de espólios e minérios de volta para casa."
				""
				"Também é perfeito para aqueles que desejam um estilo de vida nômade."
