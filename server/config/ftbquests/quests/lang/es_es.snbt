	quest.157239360F696AF7.quest_subtitle: "Completa el capítulo de la misión."
	quest.157239360F696AF7.title: "&5Ocultismo"
	quest.159FD866444D704A.quest_desc: [
		"&l¿CÓMO SE USA?&r"
		"1. Pon un mob en el frasco:"
		"&8- Realiza el &bRitual de Contención&r&8."
		"&8- Coloca el &bFrasco de Contención&r &8dentro del rango &8del ritual."
		"&8- Coloca el &2mob&r &8dentro del rango &8del ritual."
		""
		"2. Rango"
		"&8- &bFrasco de Contención&r&8: dentro de un radio de &93 bloques&r &8del Brasero Ritual."
		"&8- &2Mob&r&8: dentro de un radio de &96 bloques&r &8del Brasero Ritual. (la wiki dice 3 pero es 6)"
		""
		"3. Libera al mob (opcional)"
		"&8- Usa el hechizo &5Disipar&r &8en el frasco."
		"&8(agáchate + click derecho con el hechizo)"
		""
		""
		"&4NOTA 1&r: si no has leído la misión anterior, puedes &2PAUSAR&r el ritual con una &4señal de redstone&r."
		""
		"&4NOTA 2&r: algunos mobs están &4en la lista negra&r para Drygmy"
		"&8+ Mantén el &bFrasco de Contención&r &8con ese mob, debería decir"
		"&8+ Alternativamente, activa &6información avanzada&r &8(F3+H en la pantalla F3), busca la etiqueta &bjar_blacklist &8en el &bhuevo de generación&8"
		""
		"{@pagebreak}"
		"RitualBrazierTile.java para más información"
		"&8public void tick()"
	]
	quest.15B6718AFA5E6959.quest_desc: [
		"&6Extrae&r &bNúcleos de Generador&r de los &bGeneradores Vanilla&r."
		""
		"&cPrepárate para un desafío…"
	]
	quest.15C38E0D2B205FB4.title: "Agua para el Condensador"
	quest.15CB4C73B630D833.quest_desc: [
