	quest.1AE719655A757BF1.quest_desc: [
		"  El taladro que te llevará a los límites más lejanos de la tecnología."
		""
		"  Hecho de ese &bTitanio&r súper ligero pero resistente, podrás alimentar tus reactores y entrar en la era cuántica."
	]
	quest.1AE719655A757BF1.title: "Taladro de Titanio"
	quest.1AEF6E844F39155D.quest_desc: [
		"  &6Transforma&b:"
		""
		"• Bloques de &bDiamante&r en &b&nmineral crudo de celestigema&r"
		""
		"• Bloques de &bOro&r en &b&omineral crudo de blazegold&r"
		""
		"• Bloques de &bHierro&r en &b&omineral crudo de ferricore&r"
