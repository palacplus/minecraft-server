	quest.58E5ADE9A50BDF29.quest_desc: ["Esta Vara está pre-afinada para encontrar &bBrotes de Amatista&r. La &bAmatista&r se usa bastante en alquimia y es &6necesaria&r para Varas de Adivinación mejores."]
	quest.58ED87D90B7F7168.quest_desc: [
