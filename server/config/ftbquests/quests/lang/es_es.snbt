	quest.1A9827E5F8B7CF39.title: "Tubo Presurizado Avanzado"
	quest.1A9AD40B2F094DCF.quest_desc: [
		"La &bMejora de Generador de Piedra&r se usa en casos específicos para generar &7piedra&r según sea necesario. "
		""
		"Es una mejora de &3caso especial&r que podrías necesitar más adelante. "
		""
		"Es bueno recordar que existe."
	]
