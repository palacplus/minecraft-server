	quest.188CF922D562E21A.quest_subtitle: "¿Jugando en Equipo?"
	quest.18956DB32D96ED2B.quest_desc: ["¿Ya una mejora? ¿Intentando llevar tu casa contigo? ¡Buena idea! Las tiendas de campaña suelen lastimar la espalda."]
