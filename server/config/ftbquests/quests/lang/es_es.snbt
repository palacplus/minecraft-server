	quest.264F371D2A18EAEC.quest_desc: [
		"El &bTubo Presurizado Básico&r es capaz de &6transportar&r una plétora de cosas diferentes, como &egases&r, &atipos de infusión&r, &dpigmentos&r y &5lodos&r."
		""
		"Cada tubo agregado a la red añade &94,000mb/t&r de capacidad total de red y rendimiento base. "
		""
		"Si el tubo mismo está &6extrayendo&r los contenidos, el tubo extractor está limitado a &9750mb/t&r. "
		""
		"Si la máquina o contenedor empuja automáticamente los contenidos al tubo, entonces la tasa de transferencia es &94000mb/t&r por cada tubo en la red."
	]
	quest.264F371D2A18EAEC.title: "Tubo Presurizado Básico"
	quest.2675A4EA019B383F.quest_desc: [
		"Necesitarás hacer &bTurbinas&r para &7aprovechar el vapor&r que producirás y generar &eelectricidad&r. "
