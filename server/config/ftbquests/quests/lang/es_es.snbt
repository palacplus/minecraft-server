	quest.71B6DA56399050E1.quest_desc: ["El &bDispositivo de Reducción Personal &fte permitirá &areducirte &fcon el uso de &4energía&f."]
	quest.71DD555551705B17.quest_desc: [
		"Uno de los primeros usos del &8acero&r es hacer un &bTanque Dinámico&r. "
		""
		"Es un &emultibloque&r usado para almacenar grandes cantidades de &7fluidos&r, incluyendo &egases&r."
		""
		"El tamaño mínimo del tanque que puedes construir es un cubo de &a3x3x3&r bloques y el tamaño máximo es &a18x18x18&r. "
		""
		"Cada bloque que compone el volumen total del multibloque añade &3350,000mb&r de &7almacenamiento líquido&r o &316,000,000mb&r de &ealmacenamiento de gas&r."
	]
	quest.71DD555551705B17.title: "Tanque Dinámico"
	quest.720874ECBFD3FD19.quest_desc: [
		"  &bBrasa de Fuego&r + PF → &4Brasa de Fuego Ø&r"
		""
		"  &bCarbón de Llama del Vacío&r + &cBrasa de Fuegoƒ&r → &4Llama del Vacío Ø&r"
		""
		"  &bBrasa Eclipse&r + &cLlama del Vacíoƒ&r → &4Brasa Eclipse Ø&r"
		""
		"  &4&oX&r &4Ø&r + &bgelatina&r* ➠ &c&oX&r &cƒ&r"
		""
		"    (* la gelatina debe ser de ≥ nivel)"
		""
		"   PF = fluido polimórfico"
		"    Ø = combustible &osin refinar&r  "
		"    ƒ = combustible"
		" "
	]
