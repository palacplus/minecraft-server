	quest.690D4925E05D5421.quest_desc: [
		"- El &bEnlace de Fuente Agronómico&r produce fuente &2cultivando&r cosechas/árboles jóvenes."
		"&8puedes obtener más de &bCosechas/Árboles de Maná&r"
