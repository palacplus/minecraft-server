	quest.0633D2B1E1DB778B.quest_desc: ["Obtenido al &6fundir &bPolvo de Cuarzo Certus&f, el &bSilicio&f se usa en 3 procesadores diferentes que necesitarás para avanzar."]
	quest.0633D2B1E1DB778B.title: "Silicio"
	quest.069382B7A2FC7D35.quest_desc: [
		"Se &6calcificará&r y &lperderá&r eficiencia con el tiempo hasta un mínimo de &e33%&r de eficiencia cuando no se use &bAgua Destilada&r."
		""
		"Usar un &bHacha&r en la &bCaldera&r restablecerá su calcificación."
	]
	quest.069382B7A2FC7D35.quest_subtitle: "Usa Energía Solar en lugar de Combustible Fósil."
	quest.0696635896D223CA.quest_desc: ["El Bastón de Barbagris hará exactamente eso, darte una barba gris... Solo bromeo, este bastón te ayudará a regenerar maná y potenciar tu poder de pergaminos. Este es uno de los bastones más fáciles de fabricar."]
	quest.06C4D99A90DF7711.quest_desc: ["La &bFábrica de Inyección Definitiva&r te permite procesar &a9&r recetas de inyección a la vez."]
	quest.06C4D99A90DF7711.title: "Fábrica de Inyección Definitiva"
