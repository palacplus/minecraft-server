	quest.268B0F87CC431A51.quest_desc: ["- Necesita &bCarcasa&r para convertir el cable de nivel (&eLV&r por defecto)."]
	quest.268B0F87CC431A51.quest_subtitle: "¡Conversión más fácil!"
	quest.26A44EDA4AABFF6F.quest_desc: [
		"El &bAcero Comprimido&f se fabrica lanzando un &bLingote de Hierro&f &6al suelo&f y &6haciéndolo explotar&f con &bTNT&f, pero no siempre obtendrás retorno. "
