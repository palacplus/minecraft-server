	file.0000000000000001.title: "&lCraftoria"
	quest.000F7897FF9ED7DC.quest_desc: ["Hay &a4 etapas&f de crecimiento, al igual que los &bGrupos de Cuarzo Certus&f. Durante las &aprimeras tres etapas&f obtendrás &bPolvo de Entro&f, pero en la &acuarta etapa&f podrás obtener &bCristales Entroizados&f."]
