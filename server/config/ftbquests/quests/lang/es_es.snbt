	quest.1184EBAC0DADDB5F.title: "Troncos Archwood"
	quest.119752DA7C1B29B6.quest_desc: [""]
	quest.11FC8E533E897B8F.quest_desc: ["¡Con solo &b500,000 FE&f puedes invocar un &brayo&f cargando una &bbola de nieve en el energizador!!!"]
	quest.11FC8E533E897B8F.quest_subtitle: "¿Un rayo en una bola de nieve?"
	quest.12094D44D2E3DB16.quest_desc: [
		"Una &bArmadura&r que puede ser &6mejorada&r pero tiene los puntos de armadura del &7Hierro&r."
		""
