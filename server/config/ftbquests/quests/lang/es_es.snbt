	quest.0E3A8954B2AAF9F7.quest_desc: [
		"Usa el &bBrasero Ritual&r para invocar al &4Quimera Wilden&r y luego derrótalo."
		""
		"Este ítem te permitirá fabricar el nivel más alto de &bLibro de Hechizos&r."
	]
