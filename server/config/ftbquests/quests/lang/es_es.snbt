	quest.04A69DE982F47E64.title: "Turbina de Vapor HV"
	quest.04BCA6A8AE60D817.quest_desc: [
		"Coloca un &bMarco de Ítem&r en el bloque de almacenamiento junto a la torreta. Luego coloca el &bítem&r que deseas dentro."
		"&8La torreta ahora solo colocará ese ítem. (también funciona para cajones)"
	]
	quest.04BCA6A8AE60D817.quest_subtitle: "Ayuda para Automatización de Torretas"
	quest.04BCA6A8AE60D817.title: "Colocar Ítem Seleccionado"
	quest.04C21F7B2F034772.quest_desc: [
		"Usa &bBobinas Sobreenergizadas&r en el centro interior de cada cara apuntando al centro."
		""
		"Esto &6concentrará la energía&r en una &7fuente presurizada&r de &agas de polonio&r, rompiendo los átomos pesados y transformándolos en un &dGas de Antimateria&r."
	]
	quest.04C21F7B2F034772.title: "Bobina Sobreenergizada"
	quest.04E6DF90BA2FCACB.quest_desc: [
		"Este dispositivo &6convierte&r &7aire comprimido&r en &bEnergía Forge&r (&9compatible con RF y la energía de muchos otros mods&r)."
		""
		"Tiene una &3eficiencia base&r de &a40%&r, lo que significa que &7100 mL de aire&r generan &b40 FE&r."
		""
		"Las &bMejoras de Velocidad&r &creducirán&r ligeramente esta &aeficiencia&r."
		""
		"El &bDinamo&r también &6produce&r &4calor&r, que debe gestionarse para evitar una &cpérdida&r de &aeficiencia&r."
	]
	quest.0547229FF5334CF5.quest_desc: ["La &bInterfaz&f actúa como un cofre, puedes &aestablecer un ítem o fluido&f dentro de la &bInterfaz&f y extraerá ese ítem de la &5red&f para mantener el stock."]
	quest.0578945AE9664476.quest_subtitle: "Obtenido dentro del portal de las Pruebas del Despertar."
	quest.05A0AC380BB141A0.quest_desc: ["El &bTransportador Restrictivo&r es un tipo de &bTransportador Logístico&r que prácticamente funciona como una tubería de \"&6desbordamiento&r\". Cuando los &3ítems&r no tienen a dónde más ir, &6viajarán&r a través del &bTransportador Restrictivo&r."]
	quest.05A0AC380BB141A0.title: "Transportador Restrictivo"
	quest.05B2AA73EAEDCCF4.quest_desc: [
		"Estos &bBuses de Exportación&r tienen funcionalidad más avanzada en comparación con el &bBus de Exportación&r regular."
		""
		"&bBus de Exportación por Etiqueta&r exporta ítems de etiquetas filtradas."
		""
		"&bBus de Exportación por Mod&r exporta ítems de mods filtrados."
		""
		"&bBus de Exportación Preciso&r exporta la cantidad exacta de ítems que establezcas, ni más ni menos."
		""
		"&bBus de Exportación por Umbral&r exporta ítems cuando la cantidad está por encima/debajo del umbral establecido."
	]
	quest.05B2AA73EAEDCCF4.title: "Buses de Exportación Avanzados"
	quest.05E2E87CF3F9A5FB.quest_desc: ["Hecho con &4Redstone&r y &cDiesel&r, usado para la &bMejora de Velocidad&r."]
	quest.05E2E87CF3F9A5FB.title: "&6Lubricante"
	quest.05E7C7E41BA79426.quest_subtitle: "Carga Cuádruple"
	quest.060D9F59EB26C7BD.title: "Cloruro de Hidrógeno"
	quest.061C09A44A80D7D8.quest_desc: [
		"Consigue el &bAparato de Encantamiento de Wixie&r"
		""
		"&l1. ¿Qué tiene de especial?&r"
		"En lugar de colocar &9x ítems&r en &bx pedestales&r,"
		"¿por qué no simplemente poner esos &9x ítems&r en un &bcofre&r/&bbarril&r?"
		""
		"&l2. ¿Cómo conseguirlo?&r"
		"&6Clic derecho&r en el &bAparato de Encantamiento&r con un &bAmuleto de Wixie&r."
		"&8(convertirá el bloque en un &bAparato de Encantamiento de Wixie&r&8)"
		""
		"&l3. ¿Cómo funciona?&r"
		"Mismo concepto que el &5Amuleto de Wixie&r. Consulta la &bPágina 2&r de esa misión :)"
		""
		"{ \"text\": \"Haz clic aquí\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"183EB573F8F1DC8C\" }}"
		""
		""
		"&4NOTA&r: el rango será el mismo que el &bCaldero de Wixie&r."
	]
