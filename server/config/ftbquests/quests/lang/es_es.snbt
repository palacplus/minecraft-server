	quest.6B0418E2AC06FF09.title: "Herramientas y Armas de Oro Ígneo"
	quest.6B275A372AE020A8.quest_desc: [
		"&bPFC&r + &bFluido Polimórfico&r → &5Fluido de Portal Inestable&r"
		""
		"&5Fluido de Portal Inestable&r + &bgelatina*&r ➠ &dFluido de Portal Estable&r"
		""
		"*gelatina ≥ nivel 3"
		""
		"PFC = Catalizador de Fluido de Portal"
		"Inestable = '"
		"Estable = ''"
		""
		"El &5Fluido de Portal Inestable&r solo puede existir en &3El End&r."
		""
