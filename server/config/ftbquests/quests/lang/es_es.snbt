	quest.1E6ADDD42C99274D.quest_subtitle: "Todas estas riquezas son mías"
	quest.1E7FD1EBAE4891FA.quest_desc: [
		"Cada jugador tiene una barra de maná/fuente "
		"&8(abajo a la izquierda cuando sostienes cualquier &bLibro de Hechizos&r &8en la &6mano principal&r&8)"
		""
		"Tiene las siguientes propiedades:"
		"- Maná máximo"
		"- Tasa de regeneración"
		""
		"Usar un &bLibro de Hechizos&r de mayor nivel:"
		"- Aumenta el maná máximo"
		"- Aumenta la tasa de regeneración"
		""
		"Desbloquear un nuevo &5glifo&r:"
		"- Aumenta el maná máximo"
		"- Aumenta la tasa de regeneración"
		""
		"Usar el conjunto de &5armadura del mod&r:"
		"- Aumenta el maná máximo"
		"- Aumenta la tasa de regeneración"
		""
		"Usar un trinket especial:"
		"- Aumenta el maná máximo / aumenta la regeneración / da &2descuento&r en el uso de hechizos"
		""
		"Aplicar el encantamiento &6Impulso de Maná&r:"
		"- Aumenta el maná máximo"
		""
		"Aplicar el encantamiento &6Regeneración de Maná&r:"
		"- Aumenta la regeneración de maná"
		""
		"Beber una &bPoción de Regeneración de Maná&r:"
		"- Aumenta la regeneración de maná"
		""
		""
		"&4NOTA&r: invocar un familiar reservará un &9porcentaje&r para ese familiar hasta que lo &5Disperses&r."
	]
