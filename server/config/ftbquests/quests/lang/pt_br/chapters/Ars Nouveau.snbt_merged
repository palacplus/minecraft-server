	quest.061C09A44A80D7D8.quest_desc: [
		"Obtenha o &bAparato de Encantamento da Wixie&r"
		""
		"&l1. O que há de tão bom nisso?&r"
		"Em vez de colocar &9x itens&r em &bx pedestais&r, "
		"por que não colocar esses &9x itens&r em um &bbaú&r/&bbarril&r?"
		""
		"&l2. Como obter?&r"
		"&6Clique com o botão direito&r no &bAparato de Encantamento&r com um &bAmuleto de Wixie&r."
		"&8(isso converterá o bloco no &bAparato de Encantamento da Wixie&r&8)"
		""
		"&l3. Como funciona?&r"
		"Mesmo conceito do &5Amuleto de Wixie&r. Verifique a &bPágina 2&r daquela missão :)"
		""
		"{ \"text\": \"CLIQUE AQUI\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"183EB573F8F1DC8C\" } }"
		""
		""
		"&4NOTA&r: o alcance será o mesmo do &bCaldeirão da Wixie&r."
	]
