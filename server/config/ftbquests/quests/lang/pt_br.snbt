	quest.1A9AD40B2F094DCF.quest_desc: [
		"A &bMelhoria Geradora de Pedra&r é usada em casos específicos para gerar &7pedra&r conforme necessário. "
		""
		"É uma melhoria de &3caso de uso especial&r que você pode precisar no futuro. "
		""
