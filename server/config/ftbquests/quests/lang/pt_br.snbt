	quest.51A8026A0F8A83B1.quest_desc: ["Esmeraldas podem ser encontradas minerando, explorando ou trocando com aldeões e são usadas para criar os Pergaminhos de Evocação."]
	quest.51B59A987F916C7A.quest_desc: [
		"Um dispositivo de armazenamento portátil que pode armazenar de &a256&r até &c1 BILHÃO&r de itens por slot."
		""
		""
		"&8&lRecursos:"
		"- &3Slots Maiores: "
		"Armazene mais itens por slot do que o normalmente possível. Até 1 bilhão de itens em um único slot."
		""
		"- &3Tamanhos Diferentes: "
		"Do Banco &71&r com 9 slots até o Banco &c7&r com 108 slots, cada um com tamanhos de slot crescentes."
		""
		""
		"&8&lModos de Coleta:"
		"- &aColetar tudo&r: "
		"Todos os itens coletados irão automaticamente para o &bBanco&r em vez do seu inventário."
		""
		"- &1Coleta Filtrada&r: "
		"Os itens só irão para &rBancos&r se já contiverem itens correspondentes."
		""
		"- &5Anular excesso&r: "
		"Semelhante à Coleta Filtrada, mas se não houver espaço sobrando no &bBanco&r, o item é anulado."
		""
		"- &cSem coleta&r: "
		"Os itens vão direto para o seu inventário."
		""
		""
		"&8&lModos de Construção:"
		"- &aModo de Construção&r: "
		"Escolha qualquer bloco dentro do seu &bBanco&r e coloque-o diretamente a partir do item &bBanco&r."
		"Role enquanto estiver agachado para escolher o bloco."
		""
		"- &3Modo de Construção Aleatório&r: "
		"Semelhante ao Modo de Construção, mas os blocos são escolhidos aleatoriamente."
		""
		"- &eModo Bolsa: "
		"Clique direito para abrir a tela de inventário do &bBanco&r."
		"Clique direito enquanto estiver agachado para mudar o modo de construção."
	]
	quest.51B59A987F916C7A.quest_subtitle: "Uma solução de armazenamento portátil!"
	quest.51E386BC7692D06C.quest_desc: ["Para &6estabelecer&r uma &6rede Logística Mercurial&r, estes &bFios&r devem ser usados para &6ligar&r entre entradas e saídas. &bNós de Conexão&r permitem que múltiplos fios convirjam para um ponto, se necessário."]
	quest.51E386BC7692D06C.title: "Conexões Mercuriais"
	quest.51ECF72F223BDB3A.title: "Café"
	quest.51F5C6D60D719DC4.quest_desc: [
		"&bLatão&r—uma liga simples de &bCobre&r e &bZinco,&r mas você precisará &6visitar&r o Nether para se &6equipar&r para fazê-lo."
		""
		"&6Leve&r vários &bQueimadores de Blaze&r vazios quando for... você pode usá-los repetidamente em um &bGerador de Blaze&r para &6capturar&r tantos blazes quantos &bQueimadores de Blaze&r você tiver."
		""
		"Assim que você tiver &bLatão&r, poderá &6fabricar&r os itens na ala de &c\"Latão\"&r: o &bImplantador&r para &crealizar o que são normalmente ações do jogador&r, versões mais inteligentes de blocos mais básicos do Create, e boas escolhas para decoração também. Colocamos o próprio &bQueimador de Blaze&r lá também, embora é claro que você já tenha feito um."
	]
	quest.5221657F939FE63B.quest_desc: ["Use a Forja de Pergaminhos e um Frasco de Raios para criar um Pergaminho de Raios."]
	quest.5253D3AA5B45369E.quest_desc: [
		"Neste falamos sobre o &bglifo de forma de Projétil&r."
		""
		"Ele é especial, pois aplica &5Efeitos de Feitiço&r em cada projétil."
		"&4NOTA&r: &bferramentas de Encantador&r podem não seguir isso ... &0(o que posso dizer, mod de magia)&r"
		""
		"&8Projétil -> Perfurar -> Perfurar -> Perfurar -> Quebrar -> Perfurar&r"
		"- &bGlifo de aumento Perfurar&r: fará o projétil atingir mais 1 bloco por glifo."
		"- &bGlifo de Projétil&r com 3 &bglifos de aumento Perfurar&r: ele perfurará mais 3 &bblocos&r"
		"- &5Efeitos de Feitiço&r neste caso serão: &8Quebrar -> Perfurar&r"
		"=> Um projétil atingindo 4 vezes, cada vez aplica os &5Efeitos de Feitiço&r acima"
		""
		""
		"Quantos &bblocos&r você acha que ele quebrará? (verifique a &bPágina 2&r para resposta)"
		""
		"{@pagebreak}"
		"5 blocos? &4Você está errado&r"
		""
		"8 blocos? &2Correto&r"
		"&8Um projétil atingindo 4 vezes, cada vez aplica os &5Efeitos de Feitiço&r acima"
		"&8<=> Um projétil atingindo 4 vezes, cada vez quebrando 1 bloco e o bloco atrás dele&r"
		""
		""
		"&4NOTA&r: &bFerramentas de Feitiço&r não seguirão isso &8:(&r"
	]
