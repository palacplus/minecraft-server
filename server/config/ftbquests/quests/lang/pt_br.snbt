	quest.6201E6DF709C29D0.quest_desc: [
		"  A &barmadura de ferricore&r é tão forte e durável quanto a &barmadura de ferro&r."
		""
		"  Ela também pode ser &6melhorada&r para níveis mais altos com o &bmodelo&r apropriado."
