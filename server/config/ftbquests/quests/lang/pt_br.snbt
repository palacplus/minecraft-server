	quest.264F371D2A18EAEC.quest_desc: [
		"O &bTubo Pressurizado Básico&r é capaz de &6transportar&r uma pletora de coisas diferentes, como &egases&r, &atipos de infusão&r, &dpigmentos&r e &5polpas&r."
