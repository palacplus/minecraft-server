	quest.71B6DA56399050E1.quest_desc: ["O &bDispositivo de Encolhimento Pessoal &fpermitirá que você &aencolha &fcom o uso de &4energia&f."]
	quest.71B6DA56399050E1.title: "&aDispositivo de Encolhimento Pessoal"
	quest.71DD555551705B17.quest_desc: [
		"Um dos primeiros usos do &8aço&r é fazer um &bTanque Dinâmico&r. "
		""
		"É um &emulti-bloco&r usado para armazenar grandes quantidades de &7fluidos&r, incluindo &egases&r."
		""
		"O tamanho mínimo do tanque que você pode construir é um cubo de &a3x3x3&r blocos e o tamanho máximo é &a18x18x18&r. "
		""
		"Cada bloco que compõe o volume total do multibloco adiciona &3350.000mb&r de &7armazenamento de líquido&r ou &316.000.000mb&r de &7armazenamento de gás&r."
	]
	quest.71DD555551705B17.title: "Tanque Dinâmico"
	quest.720874ECBFD3FD19.quest_desc: [
		"  &bBrasa de Blaze&r + FP → &4Brasa de Blaze Ø&r"
		""
		"  &bCarvão VoidFlame&r + &cBrasa de Blazeƒ&r → &4VoidFlame Ø&r"
		""
		"  &bBrasa do Eclipse&r + &cVoidFlameƒ&r → &4Brasa do Eclipse Ø&r"
		""
		"  &4&oX&r &4Ø&r + &bgosma&r* ➠ &c&oX&r &cƒ&r"
		""
		"    (* gosma deve ser de ≥ nível)"
		""
		"   FP = fluido polimórfico"
		"    Ø = combustível &onão refinado&r  "
		"    ƒ = combustível"
		" "
	]
	quest.720874ECBFD3FD19.quest_subtitle: "JDT Fluídica 101"
