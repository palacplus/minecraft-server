	quest.3A20D522302FE7B9.title: "Processadores Básicos"
	quest.3A23D98042990591.title: "Infusor Químico para Trióxido de Enxofre"
	quest.3A5A59C7AEA670C7.quest_desc: ["&bCírculo de Aviar&r é o primeiro pentáculo que você preparará. É para &6invocar Foliot&r. &6Consulte&r o &bDicionário dos Espíritos&r para saber como montá-lo."]
	quest.3A5A59C7AEA670C7.quest_subtitle: "Primeiro ritual"
