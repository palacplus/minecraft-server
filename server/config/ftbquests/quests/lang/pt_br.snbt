	quest.4303A1A434C07540.quest_desc: [
		"Espíritos Zeladores podem&6 pegar&r itens e &6depositá-los&r em &bcontêineres&r."
		""
		"Eles são particularmente úteis para reunir os produtos de outros espíritos."
	]
	quest.4303A1A434C07540.quest_subtitle: "Limpo e arrumado"
	quest.4303A1A434C07540.title: "Ritual: Invocar Foliot Zelador"
	quest.431FA8EF8194D39B.quest_desc: [
		"🦀 🦀 🦀 Caranguejo Caranguejo Caranguejo 🦀 🦀 🦀 "
		""
		"Fará a &6arqueologia&r (areia/cascalho suspeito) de areia/cascalho normal."
		""
		"- Raio: &93 blocos&r do bloco de armazenamento."
		""
		"- Vincule com &bVarinha do Domínio&r."
		""
		"- Fonte necessária: SIM."
		""
		"Areia:"
		"&8- ARQUEOLOGIA_POCO_DESERTO"
		"&8- ARQUEOLOGIA_PIRAMIDE_DESERTO"
		"&8- ARQUEOLOGIA_RUINA_OCEANICA_QUENTE"
		""
