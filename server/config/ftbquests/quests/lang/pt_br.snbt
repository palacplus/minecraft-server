	quest.0C34B97F1EA88415.quest_subtitle: "Uma maneira de se teletransportar facilmente para fora das cavernas."
	quest.0C37E9D8A7823264.quest_desc: ["A Bengala do Artífice ajuda a caminhar para todos vocês velhinhos - de novo, brincadeira. Este cajado dará uma redução no tempo de recarga e tempo de lançamento e aumentará seu poder de feitiço. Este é um pouco mais caro que o cajado do Barba-Cinza, no entanto, vale a pena para lançar feitiços maiores (Faça desses cajados algo único)."]
	quest.0C53E42899D3D271.quest_desc: ["&6Controle&r simples de &bredstone&r para &bEixos&r ou &bRodas Dentadas&r de tração."]
	quest.0C6D0B1C1AF75292.quest_desc: [
		"  Winston? Você tem toda razão."
		""
		"  O &bReator Químico&r pode ser usado como uma máquina fechada para aproveitar a &6reação química entre substâncias&r neste mundo para fazer coisas novas."
		""
		"  O &bReator Químico&r incentivará essas reações e as manterá isoladas para que você não se machuque ou fique doente com fumaças, líquidos ou sólidos liberados."
		""
		"  Agora, o que me diz? Vamos cozinhar."
	]
	quest.0C6D0B1C1AF75292.quest_subtitle: "Diga meu Nome!"
