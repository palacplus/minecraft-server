	quest.1A8D5373290BC1A6.quest_subtitle: "Armazenamento mágico"
	quest.1A9827E5F8B7CF39.quest_desc: [
		"O &bTubo Pressurizado Avançado&r adicionará &916.000mb/t&r por tubo à capacidade total e taxa de transferência base da rede de tubos. "
		""
